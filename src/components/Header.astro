---
import { siteConfig } from '../data/site-config';
---

<header class="site-header sticky top-0 z-50 w-full" id="site-header">
  <!-- Scroll progress bar -->
  <div class="scroll-progress-bar h-[3px] bg-gradient-to-r from-primary-500 to-accent-500 w-0 absolute top-0 left-0 z-10"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-14">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-3 flex-shrink-0" transition:name="logo">
        <img src="/images/logo.webp" alt="Integer Training logo - accredited online course provider" class="h-8 lg:h-12 w-auto" width="48" height="48" />
      </a>

      <!-- Desktop Navigation -->
      <nav class="hidden lg:flex items-center gap-1" aria-label="Main navigation">
        <a href="/" class="px-4 py-2 text-neutral-700 hover:text-primary-500 font-medium transition-colors duration-300 rounded-xl hover:bg-primary-50">
          Home
        </a>

        <!-- Courses Dropdown -->
        <div class="nav-item relative">
          <a href="/courses" class="px-4 py-2 text-neutral-700 hover:text-primary-500 font-medium transition-colors duration-300 rounded-xl hover:bg-primary-50 flex items-center gap-1">
            Courses
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </a>
          <div class="nav-dropdown absolute top-full left-0 mt-2 w-72 glass rounded-xl shadow-brand-lg p-2">
            {siteConfig.services.map((service) => (
              <a
                href={`/courses/${service.slug}`}
                class="block px-4 py-3 rounded-lg text-neutral-700 hover:text-primary-600 hover:bg-primary-50 transition-all duration-200 text-sm font-medium"
              >
                {service.name}
              </a>
            ))}
          </div>
        </div>

        <!-- Locations Dropdown -->
        <div class="nav-item relative">
          <a href="/locations" class="px-4 py-2 text-neutral-700 hover:text-primary-500 font-medium transition-colors duration-300 rounded-xl hover:bg-primary-50 flex items-center gap-1">
            Locations
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </a>
          <div class="nav-dropdown absolute top-full left-0 mt-2 w-56 glass rounded-xl shadow-brand-lg p-2">
            {siteConfig.locations.map((location) => (
              <a
                href={`/locations/${location.slug}`}
                class="block px-4 py-3 rounded-lg text-neutral-700 hover:text-primary-600 hover:bg-primary-50 transition-all duration-200 text-sm font-medium"
              >
                {location.city}
              </a>
            ))}
          </div>
        </div>

        <a href="/about" class="px-4 py-2 text-neutral-700 hover:text-primary-500 font-medium transition-colors duration-300 rounded-xl hover:bg-primary-50">
          About
        </a>

        <a href="/contact" class="px-4 py-2 text-neutral-700 hover:text-primary-500 font-medium transition-colors duration-300 rounded-xl hover:bg-primary-50">
          Contact
        </a>
      </nav>

      <!-- Desktop CTA -->
      <div class="hidden lg:flex items-center gap-4">
        <a
          href={`tel:${siteConfig.phone.replace(/\s/g, '')}`}
          class="text-base font-bold text-neutral-900 hover:text-primary-500 transition-colors duration-300 flex items-center gap-2"
        >
          <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          {siteConfig.phone}
        </a>
        <a
          href={`https://wa.me/44${siteConfig.whatsapp.replace(/^0/, '').replace(/\s/g, '')}`}
          class="text-green-600 hover:text-green-700 transition-colors duration-300 p-2"
          aria-label="WhatsApp us"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" /></svg>
        </a>
        <a href="/cart" class="relative text-neutral-600 hover:text-primary-500 transition-colors duration-300 p-2" aria-label="Shopping cart">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
          <span id="cart-badge-desktop" class="cart-badge hidden absolute -top-0.5 -right-0.5 w-5 h-5 bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center">0</span>
        </a>
        <a
          href="/contact"
          class="btn-primary bg-gradient-to-r from-accent-500 to-accent-600 text-neutral-900 px-6 py-2.5 rounded-xl font-semibold text-sm shadow-brand hover:shadow-brand-lg hover:-translate-y-0.5 active:translate-y-0 active:shadow-brand transition-all duration-300"
        >
          Enquire Now
        </a>
      </div>

      <!-- Mobile Actions -->
      <div class="lg:hidden flex items-center gap-1">
        <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="text-neutral-700 hover:text-primary-500 transition-colors duration-300 p-2" aria-label="Call us">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        </a>
        <a href={`https://wa.me/44${siteConfig.whatsapp.replace(/^0/, '').replace(/\s/g, '')}`} class="text-green-600 hover:text-green-700 transition-colors duration-300 p-2" aria-label="WhatsApp us">
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" /></svg>
        </a>
        <a href="/cart" class="relative text-neutral-600 hover:text-primary-500 transition-colors duration-300 p-2" aria-label="Shopping cart">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>
          <span id="cart-badge-mobile" class="cart-badge hidden absolute -top-0.5 -right-0.5 w-5 h-5 bg-red-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center">0</span>
        </a>
      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="relative w-10 h-10 flex flex-col items-center justify-center gap-1.5 rounded-xl hover:bg-neutral-100 transition-colors duration-300"
        aria-label="Toggle menu"
        aria-expanded="false"
      >
        <span class="hamburger-bar block w-6 h-0.5 bg-neutral-700 rounded-full origin-center"></span>
        <span class="hamburger-bar block w-6 h-0.5 bg-neutral-700 rounded-full origin-center"></span>
        <span class="hamburger-bar block w-6 h-0.5 bg-neutral-700 rounded-full origin-center"></span>
      </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="lg:hidden hidden bg-white/95 backdrop-blur-xl border-t border-neutral-100">
    <div class="max-w-7xl mx-auto px-4 py-6 space-y-1">
      <a href="/" class="block px-4 py-3 text-neutral-700 hover:text-primary-500 hover:bg-primary-50 rounded-xl font-medium transition-all duration-200">Home</a>

      <div class="px-4 py-2">
        <p class="text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-2">Courses</p>
        {siteConfig.services.map((service) => (
          <a
            href={`/courses/${service.slug}`}
            class="block px-4 py-2.5 text-neutral-600 hover:text-primary-500 hover:bg-primary-50 rounded-lg text-sm transition-all duration-200"
          >
            {service.name}
          </a>
        ))}
        <a href="/courses" class="block px-4 py-2.5 text-primary-500 font-medium text-sm">View All Courses &rarr;</a>
      </div>

      <div class="px-4 py-2">
        <p class="text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-2">Locations</p>
        {siteConfig.locations.map((location) => (
          <a
            href={`/locations/${location.slug}`}
            class="block px-4 py-2.5 text-neutral-600 hover:text-primary-500 hover:bg-primary-50 rounded-lg text-sm transition-all duration-200"
          >
            {location.city}
          </a>
        ))}
        <a href="/locations" class="block px-4 py-2.5 text-primary-500 font-medium text-sm">View All Locations &rarr;</a>
      </div>

      <a href="/about" class="block px-4 py-3 text-neutral-700 hover:text-primary-500 hover:bg-primary-50 rounded-xl font-medium transition-all duration-200">About</a>
      <a href="/contact" class="block px-4 py-3 text-neutral-700 hover:text-primary-500 hover:bg-primary-50 rounded-xl font-medium transition-all duration-200">Contact</a>

      <div class="pt-4 px-4 space-y-3">
        <a
          href={`tel:${siteConfig.phone.replace(/\s/g, '')}`}
          class="flex items-center gap-2 text-neutral-900 font-bold text-lg"
        >
          <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
          {siteConfig.phone}
        </a>
        <a
          href={`https://wa.me/44${siteConfig.whatsapp.replace(/^0/, '').replace(/\s/g, '')}`}
          class="flex items-center gap-2 text-neutral-600 font-medium"
        >
          <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" /></svg>
          WhatsApp
        </a>
        <a
          href="/contact"
          class="btn-primary block text-center bg-gradient-to-r from-accent-500 to-accent-600 text-neutral-900 px-6 py-3 rounded-xl font-semibold shadow-brand hover:shadow-brand-lg transition-all duration-300"
        >
          Enquire Now
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  document.addEventListener('astro:page-load', () => {
    const header = document.getElementById('site-header');
    const progressBar = header?.querySelector('.scroll-progress-bar') as HTMLElement | null;
    const menuBtn = document.getElementById('mobile-menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');

    if (!header) return;

    // Scroll effect - glass morphism on scroll
    const handleScroll = () => {
      const scrollY = window.scrollY;
      if (scrollY > 80) {
        header.classList.add('header-scrolled');
      } else {
        header.classList.remove('header-scrolled');
      }

      // Progress bar
      if (progressBar) {
        const scrollTop = document.documentElement.scrollTop;
        const scrollHeight = document.documentElement.scrollHeight - window.innerHeight;
        const progress = scrollHeight > 0 ? (scrollTop / scrollHeight) * 100 : 0;
        progressBar.style.width = `${progress}%`;
      }
    };

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();

    // Mobile menu toggle
    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', () => {
        const isOpen = !mobileMenu.classList.contains('hidden');
        mobileMenu.classList.toggle('hidden');
        menuBtn.classList.toggle('menu-open');
        menuBtn.setAttribute('aria-expanded', String(!isOpen));
      });
    }

    // Cart badge
    function updateCartBadge() {
      try {
        const cart = JSON.parse(localStorage.getItem('integer_cart') || '{}');
        const count = Object.keys(cart).length;
        ['cart-badge-desktop', 'cart-badge-mobile'].forEach((id) => {
          const badge = document.getElementById(id);
          if (!badge) return;
          if (count > 0) {
            badge.textContent = String(count);
            badge.classList.remove('hidden');
          } else {
            badge.classList.add('hidden');
          }
        });
      } catch {}
    }

    updateCartBadge();
    window.addEventListener('cart-updated', updateCartBadge);
    window.addEventListener('storage', updateCartBadge);
  });
</script>
