---
import GradientMesh from './GradientMesh.astro';
import { siteConfig } from '../data/site-config';

interface Props {
  testimonials?: typeof siteConfig.testimonials;
  title?: string;
}

const { testimonials = siteConfig.testimonials, title = 'What Our Students Say' } = Astro.props;
---

<section class="relative py-24 lg:py-32 overflow-hidden">
  <GradientMesh variant="section" />

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12 lg:mb-16">
      <div class="flex items-center justify-center gap-2 mb-4">
        {[1, 2, 3, 4, 5].map(() => (
          <svg class="w-6 h-6 text-accent-500" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
          </svg>
        ))}
      </div>
      <h2 class="section-heading font-display font-bold text-3xl md:text-4xl lg:text-5xl text-neutral-900 mb-4">
        {title.includes('Students') ? (
          <>What Our <span class="text-primary-500">Students</span> Say</>
        ) : (
          <Fragment set:html={title} />
        )}
      </h2>
      <p class="text-neutral-600 text-lg">
        Rated {siteConfig.stats.trustpilotRating}/5 on Trustpilot from {siteConfig.stats.trustpilotReviews} reviews
      </p>
    </div>

    <!-- Marquee testimonials -->
    <div class="relative" aria-label="Student testimonials" role="region">
      <!-- Fade edges -->
      <div class="absolute left-0 top-0 bottom-0 w-20 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"></div>
      <div class="absolute right-0 top-0 bottom-0 w-20 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"></div>

      <div class="overflow-hidden">
        <div class="marquee-track" aria-live="polite">
          {/* Duplicate for seamless loop */}
          {[...testimonials, ...testimonials].map((testimonial) => (
            <div class="flex-shrink-0 w-80 md:w-96">
              <div class="bg-white/80 backdrop-blur-xl border border-white/40 rounded-2xl p-6 shadow-brand-sm h-full">
                <!-- Stars -->
                <div class="flex items-center gap-1 mb-4">
                  {Array.from({ length: testimonial.rating }).map(() => (
                    <svg class="w-4 h-4 text-accent-500" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>

                <!-- Quote -->
                <p class="text-neutral-700 text-sm leading-relaxed mb-4 line-clamp-4">
                  &ldquo;{testimonial.quote}&rdquo;
                </p>

                <!-- Attribution -->
                <div>
                  <div class="w-10 h-0.5 bg-primary-500 rounded-full mb-2"></div>
                  <p class="font-semibold text-neutral-900 text-sm">{testimonial.name}</p>
                  <p class="text-neutral-400 text-xs">{testimonial.date}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Trustpilot link -->
    <div class="text-center mt-10">
      <a
        href={siteConfig.social.trustpilot}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 text-primary-500 font-semibold hover:text-primary-600 transition-colors duration-300"
      >
        Read more reviews on Trustpilot
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
      </a>
    </div>
  </div>
</section>
