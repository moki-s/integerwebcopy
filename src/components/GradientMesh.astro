---
interface Props {
  variant?: 'hero' | 'section' | 'cta';
  class?: string;
}

const { variant = 'hero', class: className = '' } = Astro.props;

const configs = {
  hero: [
    { size: 600, color: 'rgba(13, 148, 136, 0.15)', top: '-10%', right: '-5%' },
    { size: 500, color: 'rgba(245, 158, 11, 0.08)', bottom: '10%', left: '-10%' },
    { size: 400, color: 'rgba(22, 78, 99, 0.1)', top: '40%', right: '20%' },
  ],
  section: [
    { size: 500, color: 'rgba(13, 148, 136, 0.1)', top: '-20%', right: '-15%' },
    { size: 450, color: 'rgba(245, 158, 11, 0.06)', bottom: '-10%', left: '-10%' },
  ],
  cta: [
    { size: 550, color: 'rgba(255, 255, 255, 0.08)', top: '-15%', left: '-10%' },
    { size: 450, color: 'rgba(245, 158, 11, 0.1)', bottom: '-20%', right: '-5%' },
  ],
};

const blobs = configs[variant];
---

<div class:list={['absolute inset-0 overflow-hidden pointer-events-none', className]} aria-hidden="true">
  {
    blobs.map((blob) => (
      <div
        class="absolute rounded-full blur-3xl"
        style={`width: ${blob.size}px; height: ${blob.size}px; background: radial-gradient(circle, ${blob.color}, transparent 70%); ${blob.top ? `top: ${blob.top};` : ''} ${blob.bottom ? `bottom: ${blob.bottom};` : ''} ${blob.left ? `left: ${blob.left};` : ''} ${blob.right ? `right: ${blob.right};` : ''}`}
      />
    ))
  }
</div>
