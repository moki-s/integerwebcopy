---
import { siteConfig } from '../data/site-config';
---

<footer class="relative bg-neutral-900 text-neutral-300 overflow-hidden">
  <!-- Gradient mesh decoration -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div
      class="absolute -top-32 -right-32 w-96 h-96 rounded-full blur-3xl"
      style="background: radial-gradient(circle, rgba(13, 148, 136, 0.08), transparent 70%);"
    ></div>
    <div
      class="absolute -bottom-24 -left-24 w-80 h-80 rounded-full blur-3xl"
      style="background: radial-gradient(circle, rgba(245, 158, 11, 0.05), transparent 70%);"
    ></div>
    <!-- Branded accent shape -->
    <div
      class="absolute top-20 right-20 w-40 h-40 border border-white/5 rounded-3xl opacity-30"
      style="transform: rotate(12deg);"
    ></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-8">
    <!-- Main footer grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16">
      <!-- Brand Column -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="/" class="flex items-center gap-3 mb-6">
          <img src="/images/logo.webp" alt="Integer Training logo - accredited online course provider" class="h-10 w-auto" width="40" height="40" />
        </a>
        <p class="text-neutral-400 text-sm leading-relaxed mb-6 max-w-xs">
          {siteConfig.tagline} With over {siteConfig.stats.years} years of experience and {siteConfig.stats.students.toLocaleString()}+ successful students, we deliver accredited qualifications that advance careers.
        </p>
        <div class="flex items-center gap-2">
          <div class="flex items-center gap-0.5">
            {[1, 2, 3, 4].map(() => (
              <svg viewBox="0 0 24 24" class="w-4 h-4"><rect width="24" height="24" rx="2" fill="#00b67a"/><path d="M12 3.5l2.5 5.2 5.5.8-4 3.9 1 5.6-5-2.6-5 2.6 1-5.6-4-3.9 5.5-.8z" fill="white"/></svg>
            ))}
            <svg viewBox="0 0 24 24" class="w-4 h-4"><rect width="12" height="24" rx="2" fill="#00b67a"/><rect x="12" width="12" height="24" rx="2" fill="#dcdce6"/><path d="M12 3.5l2.5 5.2 5.5.8-4 3.9 1 5.6-5-2.6-5 2.6 1-5.6-4-3.9 5.5-.8z" fill="white"/></svg>
          </div>
          <a href={siteConfig.social.trustpilot} target="_blank" rel="noopener noreferrer" class="text-sm text-neutral-400 hover:text-accent-400 transition-colors duration-300">
            {siteConfig.stats.trustpilotRating}/5 on <span class="font-bold text-white">Trust</span><span class="font-bold text-[#00b67a]">pilot</span>
          </a>
        </div>

        <!-- Social links -->
        <div class="flex items-center gap-3 mt-4">
          {siteConfig.social.facebook && (
            <a href={siteConfig.social.facebook} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-neutral-800 hover:bg-blue-600/20 flex items-center justify-center text-neutral-400 hover:text-blue-400 transition-all duration-300" aria-label="Facebook">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          )}
          {siteConfig.social.instagram && (
            <a href={siteConfig.social.instagram} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-neutral-800 hover:bg-pink-600/20 flex items-center justify-center text-neutral-400 hover:text-pink-400 transition-all duration-300" aria-label="Instagram">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          )}
          {siteConfig.social.linkedin && (
            <a href={siteConfig.social.linkedin} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-neutral-800 hover:bg-blue-700/20 flex items-center justify-center text-neutral-400 hover:text-blue-300 transition-all duration-300" aria-label="LinkedIn">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </a>
          )}
          <a href={siteConfig.social.trustpilot} target="_blank" rel="noopener noreferrer" class="w-9 h-9 rounded-lg bg-neutral-800 hover:bg-green-600/20 flex items-center justify-center text-neutral-400 hover:text-green-400 transition-all duration-300" aria-label="Trustpilot reviews">
            <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" /></svg>
          </a>
        </div>
      </div>

      <!-- Courses Column -->
      <div>
        <h3 class="font-display font-semibold text-white text-sm uppercase tracking-wider mb-6">Courses</h3>
        <ul class="space-y-3">
          {siteConfig.services.map((service) => (
            <li>
              <a
                href={`/courses/${service.slug}`}
                class="text-neutral-400 hover:text-primary-400 transition-colors duration-300 text-sm"
              >
                {service.name}
              </a>
            </li>
          ))}
          <li>
            <a href="/courses" class="text-primary-400 hover:text-primary-300 transition-colors duration-300 text-sm font-medium">
              View All Courses &rarr;
            </a>
          </li>
        </ul>
      </div>

      <!-- Locations Column -->
      <div>
        <h3 class="font-display font-semibold text-white text-sm uppercase tracking-wider mb-6">Locations</h3>
        <ul class="space-y-3">
          {siteConfig.locations.map((location) => (
            <li>
              <a
                href={`/locations/${location.slug}`}
                class="text-neutral-400 hover:text-primary-400 transition-colors duration-300 text-sm"
              >
                {location.city}{location.isPrimary ? ' (HQ)' : ''}
              </a>
            </li>
          ))}
          <li class="pt-2">
            <a href="/about" class="text-neutral-400 hover:text-primary-400 transition-colors duration-300 text-sm">About Us</a>
          </li>
          <li>
            <a href="/contact" class="text-neutral-400 hover:text-primary-400 transition-colors duration-300 text-sm">Contact</a>
          </li>
        </ul>
      </div>

      <!-- Contact Column -->
      <div>
        <h3 class="font-display font-semibold text-white text-sm uppercase tracking-wider mb-6">Contact Us</h3>
        <ul class="space-y-4">
          <li>
            <a href={`tel:${siteConfig.phone.replace(/\s/g, '')}`} class="flex items-start gap-3 text-neutral-400 hover:text-primary-400 transition-colors duration-300 text-sm">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              <span>{siteConfig.phone}</span>
            </a>
          </li>
          <li>
            <a href={`https://wa.me/44${siteConfig.whatsapp.replace(/^0/, '').replace(/\s/g, '')}`} class="flex items-start gap-3 text-neutral-400 hover:text-green-400 transition-colors duration-300 text-sm">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" /></svg>
              <span>WhatsApp: {siteConfig.whatsapp}</span>
            </a>
          </li>
          <li>
            <a href={`mailto:${siteConfig.email}`} class="flex items-start gap-3 text-neutral-400 hover:text-primary-400 transition-colors duration-300 text-sm">
              <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              <span>{siteConfig.email}</span>
            </a>
          </li>
          <li class="flex items-start gap-3 text-neutral-400 text-sm">
            <svg class="w-5 h-5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            <span>Mon-Fri, 9am-5pm</span>
          </li>
        </ul>
      </div>
    </div>

    <!-- Accreditation partners -->
    <div class="border-t border-neutral-800 pt-8 mb-8">
      <p class="text-xs text-neutral-500 uppercase tracking-wider text-center mb-8">Accredited by</p>
      <div class="flex flex-wrap items-center justify-center gap-5">
        {siteConfig.partners.slice(0, 8).map((partner) => (
          <div class="bg-white rounded-xl px-5 py-3 flex items-center justify-center">
            <img
              src={partner.logo}
              alt={partner.name}
              class="h-12 md:h-14 w-auto object-contain max-w-[160px]"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-neutral-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-neutral-500">
        &copy; {new Date().getFullYear()} {siteConfig.companyName}. Company No: {siteConfig.companyNumber}. All rights reserved.
      </p>
      <div class="flex items-center gap-6">
        <a href="/privacy-policy" class="text-xs text-neutral-500 hover:text-primary-400 transition-colors duration-300">Privacy Policy</a>
        <a href="/terms" class="text-xs text-neutral-500 hover:text-primary-400 transition-colors duration-300">Terms & Conditions</a>
        <a href="/policies" class="text-xs text-neutral-500 hover:text-primary-400 transition-colors duration-300">Policies</a>
      </div>
    </div>

  </div>
</footer>

