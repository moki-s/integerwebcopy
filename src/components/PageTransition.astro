---
// Full-screen overlay for page transitions
---

<div
  id="page-transition-overlay"
  class="fixed inset-0 z-[60] pointer-events-none origin-right"
  style="background: linear-gradient(135deg, #0d9488, #164e63); transform: scaleX(0);"
  aria-hidden="true"
>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const overlay = document.getElementById('page-transition-overlay');
    if (!overlay) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) {
      overlay.style.display = 'none';
      return;
    }

    overlay.style.transformOrigin = 'right';
    overlay.style.transform = 'scaleX(1)';

    requestAnimationFrame(() => {
      overlay.style.transition = 'transform 0.5s cubic-bezier(0.4, 0, 0.2, 1)';
      overlay.style.transform = 'scaleX(0)';
    });
  });

  document.addEventListener('astro:before-swap', () => {
    const overlay = document.getElementById('page-transition-overlay');
    if (!overlay) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    overlay.style.transition = 'transform 0.4s cubic-bezier(0.4, 0, 0.2, 1)';
    overlay.style.transformOrigin = 'left';
    overlay.style.transform = 'scaleX(1)';
  });
</script>
