---
import BreadcrumbSchema from './schemas/BreadcrumbSchema.astro';

interface Props {
  items: Array<{ label: string; href: string }>;
}

const { items } = Astro.props;
---

<BreadcrumbSchema items={items} />

<nav aria-label="Breadcrumb" class="py-4 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto">
  <ol class="flex flex-wrap items-center gap-2 text-sm text-neutral-500">
    {
      items.map((item, index) => (
        <li class="flex items-center gap-2">
          {index > 0 && (
            <svg
              class="w-4 h-4 text-neutral-300 flex-shrink-0"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          )}
          {index === items.length - 1 ? (
            <span class="text-neutral-900 font-medium" aria-current="page">
              {item.label}
            </span>
          ) : (
            <a href={item.href} class="link-underline hover:text-primary-500 transition-colors duration-300">
              {item.label}
            </a>
          )}
        </li>
      ))
    }
  </ol>
</nav>
