---
export const prerender = false;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Admin — Integer Training</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style is:global>
      :root {
        --bg-base: #0c0f14;
        --bg-raised: #13161d;
        --bg-surface: #1a1e27;
        --bg-hover: #22272f;
        --bg-active: #2a3040;
        --border: #2a2f3a;
        --border-subtle: #1f232d;
        --text-primary: #e8ecf4;
        --text-secondary: #8b93a8;
        --text-muted: #5a6278;
        --accent: #0d9488;
        --accent-hover: #0f766e;
        --accent-soft: rgba(13,148,136,0.12);
        --accent-text: #5eead4;
        --coral: #f87171;
        --coral-soft: rgba(248,113,113,0.12);
        --amber: #fbbf24;
        --amber-soft: rgba(251,191,36,0.12);
        --green: #34d399;
        --green-soft: rgba(52,211,153,0.12);
        --blue: #60a5fa;
        --blue-soft: rgba(96,165,250,0.12);
        --purple: #a78bfa;
        --purple-soft: rgba(167,139,250,0.12);
        --radius: 10px;
        --radius-lg: 14px;
        --shadow: 0 1px 3px rgba(0,0,0,0.3), 0 0 0 1px var(--border-subtle);
        --font: 'DM Sans', system-ui, sans-serif;
        --mono: 'JetBrains Mono', monospace;
      }

      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
      body { font-family: var(--font); background: var(--bg-base); color: var(--text-primary); min-height: 100vh; font-size: 14px; line-height: 1.5; }
      ::selection { background: var(--accent); color: #fff; }
      ::-webkit-scrollbar { width: 6px; height: 6px; }
      ::-webkit-scrollbar-track { background: transparent; }
      ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
      ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

      /* ========== LOGIN ========== */
      .login-wrap {
        display: flex; align-items: center; justify-content: center;
        min-height: 100vh; padding: 1.5rem;
        background: radial-gradient(ellipse at 50% 0%, rgba(13,148,136,0.08) 0%, transparent 60%), var(--bg-base);
      }
      .login-card {
        background: var(--bg-raised); border: 1px solid var(--border);
        border-radius: var(--radius-lg); padding: 2.5rem; max-width: 380px; width: 100%;
        box-shadow: 0 8px 40px rgba(0,0,0,0.4);
      }
      .login-logo {
        width: 40px; height: 40px; background: var(--accent); border-radius: 10px;
        display: flex; align-items: center; justify-content: center; margin-bottom: 1.5rem;
        font-weight: 700; color: #fff; font-size: 18px;
      }
      .login-card h1 { font-size: 1.25rem; font-weight: 600; margin-bottom: 0.25rem; letter-spacing: -0.01em; }
      .login-card .subtitle { color: var(--text-secondary); font-size: 0.8125rem; margin-bottom: 1.75rem; }
      .login-card label { display: block; font-size: 0.75rem; font-weight: 500; color: var(--text-secondary); margin-bottom: 0.375rem; text-transform: uppercase; letter-spacing: 0.05em; }
      .login-card input {
        width: 100%; padding: 0.625rem 0.875rem; background: var(--bg-surface); border: 1px solid var(--border);
        border-radius: var(--radius); color: var(--text-primary); font-size: 0.875rem; font-family: var(--font);
        outline: none; transition: border-color 0.2s, box-shadow 0.2s;
      }
      .login-card input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-soft); }
      .login-card input::placeholder { color: var(--text-muted); }
      .btn-primary {
        width: 100%; margin-top: 1.25rem; padding: 0.625rem; background: var(--accent); color: #fff;
        font-weight: 600; border: none; border-radius: var(--radius); font-size: 0.875rem;
        cursor: pointer; transition: background 0.2s, transform 0.1s; font-family: var(--font);
      }
      .btn-primary:hover { background: var(--accent-hover); }
      .btn-primary:active { transform: scale(0.98); }
      .login-error { color: var(--coral); font-size: 0.8125rem; margin-top: 0.625rem; display: none; }

      /* ========== LAYOUT ========== */
      .app { display: none; height: 100vh; }
      .app.active { display: flex; }

      /* Sidebar */
      .sidebar {
        width: 240px; flex-shrink: 0; background: var(--bg-raised);
        border-right: 1px solid var(--border); display: flex; flex-direction: column;
        padding: 0; overflow-y: auto;
      }
      .sidebar-header {
        padding: 1.25rem 1.25rem 1rem; border-bottom: 1px solid var(--border);
        display: flex; align-items: center; gap: 0.75rem;
      }
      .sidebar-logo {
        width: 32px; height: 32px; background: var(--accent); border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-weight: 700; color: #fff; font-size: 14px; flex-shrink: 0;
      }
      .sidebar-brand { font-weight: 600; font-size: 0.875rem; letter-spacing: -0.01em; }
      .sidebar-brand span { display: block; font-size: 0.6875rem; color: var(--text-muted); font-weight: 400; }

      .sidebar-nav { padding: 0.75rem; flex: 1; }
      .sidebar-section { margin-bottom: 1.5rem; }
      .sidebar-section-label { font-size: 0.625rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); padding: 0 0.75rem; margin-bottom: 0.375rem; }

      .nav-item {
        display: flex; align-items: center; gap: 0.625rem; padding: 0.5rem 0.75rem;
        border-radius: var(--radius); color: var(--text-secondary); cursor: pointer;
        transition: all 0.15s; font-size: 0.8125rem; font-weight: 500; border: none;
        background: none; width: 100%; text-align: left; font-family: var(--font);
      }
      .nav-item:hover { background: var(--bg-hover); color: var(--text-primary); }
      .nav-item.active { background: var(--accent-soft); color: var(--accent-text); }
      .nav-item svg { width: 18px; height: 18px; flex-shrink: 0; opacity: 0.7; }
      .nav-item.active svg { opacity: 1; }
      .nav-badge {
        margin-left: auto; background: var(--accent-soft); color: var(--accent-text);
        font-size: 0.6875rem; font-weight: 600; padding: 0.125rem 0.5rem;
        border-radius: 2rem; min-width: 22px; text-align: center;
      }

      .sidebar-footer { padding: 0.75rem; border-top: 1px solid var(--border); }

      /* Main content */
      .main { flex: 1; display: flex; flex-direction: column; overflow: hidden; min-width: 0; }

      /* Top bar */
      .topbar {
        padding: 0.875rem 1.5rem; border-bottom: 1px solid var(--border);
        display: flex; align-items: center; justify-content: space-between;
        background: var(--bg-raised); flex-shrink: 0;
      }
      .topbar-title { font-size: 1.125rem; font-weight: 600; letter-spacing: -0.01em; }
      .topbar-actions { display: flex; gap: 0.5rem; align-items: center; }
      .btn-ghost {
        padding: 0.375rem 0.75rem; border-radius: var(--radius); border: 1px solid var(--border);
        background: var(--bg-surface); color: var(--text-secondary); cursor: pointer;
        font-size: 0.8125rem; font-weight: 500; transition: all 0.15s; font-family: var(--font);
        display: flex; align-items: center; gap: 0.375rem;
      }
      .btn-ghost:hover { background: var(--bg-hover); color: var(--text-primary); border-color: var(--text-muted); }
      .btn-ghost svg { width: 15px; height: 15px; }
      .btn-danger { color: var(--coral); border-color: rgba(248,113,113,0.2); }
      .btn-danger:hover { background: var(--coral-soft); color: var(--coral); }

      /* Content area */
      .content { flex: 1; overflow-y: auto; padding: 1.5rem; }

      /* Page sections */
      .page { display: none; }
      .page.active { display: block; }

      /* ========== STATS GRID ========== */
      .stats-grid {
        display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 0.75rem; margin-bottom: 1.5rem;
      }
      .stat-card {
        background: var(--bg-raised); border: 1px solid var(--border);
        border-radius: var(--radius-lg); padding: 1.25rem; position: relative; overflow: hidden;
      }
      .stat-card::before {
        content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px;
      }
      .stat-card.teal::before { background: var(--accent); }
      .stat-card.coral::before { background: var(--coral); }
      .stat-card.amber::before { background: var(--amber); }
      .stat-card.green::before { background: var(--green); }
      .stat-card.blue::before { background: var(--blue); }
      .stat-card.purple::before { background: var(--purple); }
      .stat-label { font-size: 0.75rem; font-weight: 500; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.5rem; }
      .stat-value { font-size: 2rem; font-weight: 700; letter-spacing: -0.02em; line-height: 1; }
      .stat-sub { font-size: 0.8125rem; color: var(--text-muted); margin-top: 0.5rem; }
      .stat-value.teal { color: var(--accent-text); }
      .stat-value.coral { color: var(--coral); }
      .stat-value.amber { color: var(--amber); }
      .stat-value.green { color: var(--green); }
      .stat-value.blue { color: var(--blue); }
      .stat-value.purple { color: var(--purple); }

      /* ========== FILTERS ========== */
      .toolbar {
        display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; flex-wrap: wrap;
      }
      .pill {
        padding: 0.3125rem 0.75rem; border-radius: 2rem; border: 1px solid var(--border);
        background: var(--bg-raised); color: var(--text-secondary); cursor: pointer;
        font-size: 0.75rem; font-weight: 500; transition: all 0.15s; font-family: var(--font);
      }
      .pill:hover { background: var(--bg-hover); color: var(--text-primary); }
      .pill.active { background: var(--accent-soft); color: var(--accent-text); border-color: rgba(13,148,136,0.3); }
      .pill .count { margin-left: 0.25rem; opacity: 0.6; }
      .search-input {
        margin-left: auto; padding: 0.375rem 0.75rem; background: var(--bg-surface);
        border: 1px solid var(--border); border-radius: var(--radius); color: var(--text-primary);
        font-size: 0.8125rem; font-family: var(--font); outline: none; width: 220px;
        transition: border-color 0.2s, box-shadow 0.2s;
      }
      .search-input:focus { border-color: var(--accent); box-shadow: 0 0 0 3px var(--accent-soft); }
      .search-input::placeholder { color: var(--text-muted); }

      /* ========== TABLE ========== */
      .table-container {
        background: var(--bg-raised); border: 1px solid var(--border);
        border-radius: var(--radius-lg); overflow: hidden;
      }
      table { width: 100%; border-collapse: collapse; }
      thead { background: var(--bg-surface); }
      th {
        text-align: left; padding: 0.875rem 1.125rem; font-size: 0.75rem; font-weight: 600;
        color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em;
        white-space: nowrap; border-bottom: 1px solid var(--border);
      }
      td {
        padding: 0.875rem 1.125rem; font-size: 0.875rem; border-bottom: 1px solid var(--border-subtle);
        vertical-align: middle; line-height: 1.5;
      }
      tr:last-child td { border-bottom: none; }
      tr:nth-child(even) td { background: rgba(255,255,255,0.015); }
      tr:hover td { background: var(--bg-hover); }
      .td-name { font-weight: 600; white-space: nowrap; color: var(--text-primary); font-size: 0.9375rem; }
      .td-email a { color: var(--accent-text); text-decoration: none; font-size: 0.875rem; }
      .td-email a:hover { text-decoration: underline; }
      .td-phone a { color: var(--text-secondary); text-decoration: none; white-space: nowrap; }
      .td-mono { font-family: var(--mono); font-size: 0.8125rem; color: var(--text-secondary); }
      .td-message {
        max-width: 280px; overflow: hidden; text-overflow: ellipsis;
        white-space: nowrap; color: var(--text-secondary);
      }
      .td-message:hover { white-space: normal; word-break: break-word; }
      .td-page { font-size: 0.8125rem; color: var(--text-muted); white-space: nowrap; }
      .td-date { white-space: nowrap; color: var(--text-muted); font-size: 0.875rem; }
      .td-amount { font-family: var(--mono); font-weight: 700; font-size: 1rem; white-space: nowrap; color: var(--green); }
      .td-courses { max-width: 240px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: var(--text-secondary); }
      .td-courses:hover { white-space: normal; word-break: break-word; }

      /* ========== BADGES ========== */
      .badge {
        display: inline-flex; align-items: center; padding: 0.3125rem 0.75rem;
        border-radius: 2rem; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.02em;
        cursor: pointer; transition: opacity 0.15s; text-transform: capitalize;
      }
      .badge:hover { opacity: 0.8; }
      .badge::before { content: ''; width: 7px; height: 7px; border-radius: 50%; margin-right: 0.4375rem; flex-shrink: 0; }
      .badge-new { background: var(--accent-soft); color: var(--accent-text); }
      .badge-new::before { background: var(--accent); }
      .badge-contacted { background: var(--blue-soft); color: var(--blue); }
      .badge-contacted::before { background: var(--blue); }
      .badge-enrolled { background: var(--green-soft); color: var(--green); }
      .badge-enrolled::before { background: var(--green); }
      .badge-closed { background: rgba(90,98,120,0.15); color: var(--text-muted); }
      .badge-closed::before { background: var(--text-muted); }
      .badge-pending { background: var(--amber-soft); color: var(--amber); }
      .badge-pending::before { background: var(--amber); }
      .badge-paid { background: var(--green-soft); color: var(--green); }
      .badge-paid::before { background: var(--green); }
      .badge-fulfilled { background: var(--accent-soft); color: var(--accent-text); }
      .badge-fulfilled::before { background: var(--accent); }
      .badge-refunded { background: var(--coral-soft); color: var(--coral); }
      .badge-refunded::before { background: var(--coral); }
      .badge-cancelled { background: rgba(90,98,120,0.15); color: var(--text-muted); }
      .badge-cancelled::before { background: var(--text-muted); }
      .badge-failed { background: var(--coral-soft); color: var(--coral); }
      .badge-failed::before { background: var(--coral); }
      .badge-subscription_active { background: var(--purple-soft); color: var(--purple); }
      .badge-subscription_active::before { background: var(--purple); }
      .badge-one_time { background: var(--accent-soft); color: var(--accent-text); }
      .badge-one_time::before { background: var(--accent); }
      .badge-subscription, .badge-monthly { background: var(--purple-soft); color: var(--purple); }
      .badge-subscription::before, .badge-monthly::before { background: var(--purple); }

      /* ========== DROPDOWN ========== */
      .status-cell { position: relative; }
      .status-dropdown {
        display: none; position: absolute; top: calc(100% + 4px); left: 0;
        background: var(--bg-surface); border: 1px solid var(--border);
        border-radius: var(--radius); box-shadow: 0 8px 24px rgba(0,0,0,0.3);
        z-index: 50; min-width: 140px; padding: 0.25rem; overflow: hidden;
      }
      .status-dropdown.open { display: block; }
      .status-option {
        padding: 0.4375rem 0.75rem; font-size: 0.8125rem; cursor: pointer;
        transition: background 0.1s; border-radius: 6px; color: var(--text-secondary);
      }
      .status-option:hover { background: var(--bg-hover); color: var(--text-primary); }

      /* ========== EMPTY / LOADING ========== */
      .loading-state { text-align: center; padding: 3rem; color: var(--text-muted); }
      .spinner {
        display: inline-block; width: 24px; height: 24px; border: 2.5px solid var(--border);
        border-top-color: var(--accent); border-radius: 50%; animation: spin 0.6s linear infinite;
      }
      @keyframes spin { to { transform: rotate(360deg); } }
      .empty-state { text-align: center; padding: 3rem; color: var(--text-muted); }
      .empty-icon { font-size: 2rem; margin-bottom: 0.75rem; opacity: 0.4; }

      /* ========== DETAIL DRAWER ========== */
      .drawer-overlay {
        display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5);
        z-index: 100; backdrop-filter: blur(2px);
      }
      .drawer-overlay.open { display: block; }
      .drawer {
        position: fixed; top: 0; right: -460px; bottom: 0; width: 460px;
        background: var(--bg-raised); border-left: 1px solid var(--border);
        z-index: 101; overflow-y: auto; transition: right 0.25s ease;
        box-shadow: -8px 0 40px rgba(0,0,0,0.3);
      }
      .drawer.open { right: 0; }
      .drawer-header {
        padding: 1.25rem 1.5rem; border-bottom: 1px solid var(--border);
        display: flex; align-items: center; justify-content: space-between;
        position: sticky; top: 0; background: var(--bg-raised); z-index: 1;
      }
      .drawer-header h2 { font-size: 1rem; font-weight: 600; }
      .drawer-close {
        width: 32px; height: 32px; display: flex; align-items: center; justify-content: center;
        border-radius: var(--radius); border: 1px solid var(--border); background: var(--bg-surface);
        color: var(--text-secondary); cursor: pointer; transition: all 0.15s;
      }
      .drawer-close:hover { background: var(--bg-hover); color: var(--text-primary); }
      .drawer-body { padding: 1.5rem; }
      .detail-group { margin-bottom: 1.5rem; }
      .detail-group-title { font-size: 0.6875rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 0.75rem; }
      .detail-row { display: flex; justify-content: space-between; padding: 0.5rem 0; border-bottom: 1px solid var(--border-subtle); }
      .detail-row:last-child { border-bottom: none; }
      .detail-label { color: var(--text-muted); font-size: 0.8125rem; }
      .detail-value { color: var(--text-primary); font-size: 0.8125rem; font-weight: 500; text-align: right; max-width: 60%; word-break: break-word; }
      .detail-value a { color: var(--accent-text); text-decoration: none; }
      .detail-value a:hover { text-decoration: underline; }
      .detail-message { margin-top: 0.75rem; padding: 1rem; background: var(--bg-surface); border-radius: var(--radius); color: var(--text-secondary); font-size: 0.8125rem; line-height: 1.6; white-space: pre-wrap; word-break: break-word; }

      /* ========== RESPONSIVE ========== */
      @media (max-width: 768px) {
        .sidebar { display: none; }
        .mobile-nav { display: flex !important; }
        .stats-grid { grid-template-columns: repeat(2, 1fr); }
        .search-input { width: 100%; margin-left: 0; margin-top: 0.5rem; }
        .toolbar { flex-direction: column; align-items: stretch; }
        .drawer { width: 100%; right: -100%; }
      }
      .mobile-nav {
        display: none; background: var(--bg-raised); border-bottom: 1px solid var(--border);
        padding: 0.5rem; gap: 0.25rem; overflow-x: auto;
      }
      .mobile-nav .nav-item { white-space: nowrap; justify-content: center; font-size: 0.75rem; padding: 0.5rem 0.75rem; }
    </style>
  </head>
  <body>

    <!-- ==================== APP ==================== -->
    <div id="app" class="app active">

      <!-- Mobile nav -->
      <div class="mobile-nav" id="mobile-nav">
        <button class="nav-item active" data-page="overview" onclick="switchPage('overview')">Overview</button>
        <button class="nav-item" data-page="enquiries" onclick="switchPage('enquiries')">Enquiries</button>
        <button class="nav-item" data-page="orders" onclick="switchPage('orders')">Orders</button>
      </div>

      <!-- Sidebar -->
      <aside class="sidebar">
        <div class="sidebar-header">
          <div class="sidebar-logo">IT</div>
          <div class="sidebar-brand">Integer Training <span>Admin Dashboard</span></div>
        </div>
        <nav class="sidebar-nav">
          <div class="sidebar-section">
            <div class="sidebar-section-label">Dashboard</div>
            <button class="nav-item active" data-page="overview" onclick="switchPage('overview')">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M4 5a1 1 0 011-1h4a1 1 0 011 1v5a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm10 0a1 1 0 011-1h4a1 1 0 011 1v3a1 1 0 01-1 1h-4a1 1 0 01-1-1V5zm-10 9a1 1 0 011-1h4a1 1 0 011 1v3a1 1 0 01-1 1H5a1 1 0 01-1-1v-3zm10-2a1 1 0 011-1h4a1 1 0 011 1v5a1 1 0 01-1 1h-4a1 1 0 01-1-1v-5z"/></svg>
              Overview
            </button>
          </div>
          <div class="sidebar-section">
            <div class="sidebar-section-label">Data</div>
            <button class="nav-item" data-page="enquiries" onclick="switchPage('enquiries')">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
              Enquiries
              <span class="nav-badge" id="sidebar-enq-count">0</span>
            </button>
            <button class="nav-item" data-page="orders" onclick="switchPage('orders')">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
              Orders
              <span class="nav-badge" id="sidebar-ord-count">0</span>
            </button>
          </div>
        </nav>
      </aside>

      <!-- Main -->
      <div class="main">
        <div class="topbar">
          <div class="topbar-title" id="page-title">Overview</div>
          <div class="topbar-actions">
            <button class="btn-ghost" id="refresh-btn">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
              Refresh
            </button>
            <button class="btn-ghost" id="export-btn">
              <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
              Export CSV
            </button>
          </div>
        </div>

        <div class="content">

          <!-- ===== OVERVIEW PAGE ===== -->
          <div class="page active" id="page-overview">
            <div class="stats-grid" id="overview-stats"></div>
            <h3 style="font-size:1rem;font-weight:600;margin-bottom:0.75rem;color:var(--text-primary);display:flex;align-items:center;gap:0.5rem;">
              <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="opacity:0.5;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
              Recent Enquiries
            </h3>
            <div class="table-container" id="overview-enquiries-wrap">
              <div class="loading-state" id="overview-loading"><div class="spinner"></div></div>
            </div>
            <h3 style="font-size:1rem;font-weight:600;margin:1.5rem 0 0.75rem;color:var(--text-primary);display:flex;align-items:center;gap:0.5rem;">
              <svg width="18" height="18" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="opacity:0.5;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
              Recent Orders
            </h3>
            <div class="table-container" id="overview-orders-wrap">
              <div class="loading-state"><div class="spinner"></div></div>
            </div>
          </div>

          <!-- ===== ENQUIRIES PAGE ===== -->
          <div class="page" id="page-enquiries">
            <div class="stats-grid" id="enquiry-stats"></div>
            <div class="toolbar" id="enquiry-toolbar">
              <button class="pill active" data-filter="all" data-target="enquiry">All</button>
              <button class="pill" data-filter="new" data-target="enquiry">New</button>
              <button class="pill" data-filter="contacted" data-target="enquiry">Contacted</button>
              <button class="pill" data-filter="enrolled" data-target="enquiry">Enrolled</button>
              <button class="pill" data-filter="closed" data-target="enquiry">Closed</button>
              <input type="text" class="search-input" id="enquiry-search" placeholder="Search name, email, course..." />
            </div>
            <div class="table-container">
              <div class="loading-state" id="enquiry-loading"><div class="spinner"></div></div>
              <div class="empty-state" id="enquiry-empty" style="display:none;"><div class="empty-icon">&#x1f4ed;</div>No enquiries found.</div>
              <table id="enquiry-table" style="display:none;">
                <thead><tr>
                  <th>Status</th><th>Name</th><th>Email</th><th>Phone</th><th>Course Interest</th><th>Message</th><th>Source</th><th>Date</th>
                </tr></thead>
                <tbody id="enquiry-body"></tbody>
              </table>
            </div>
          </div>

          <!-- ===== ORDERS PAGE ===== -->
          <div class="page" id="page-orders">
            <div class="stats-grid" id="order-stats"></div>
            <div class="toolbar" id="order-toolbar">
              <button class="pill active" data-filter="all" data-target="order">All</button>
              <button class="pill" data-filter="paid" data-target="order">Paid</button>
              <button class="pill" data-filter="subscription_active" data-target="order">Subscription</button>
              <button class="pill" data-filter="failed" data-target="order">Failed</button>
              <span style="margin-left:0.5rem;color:var(--text-muted);">·</span>
              <button class="pill" data-filter="card" data-target="order_method">Card</button>
              <button class="pill" data-filter="bacs_debit" data-target="order_method">BACS</button>
              <span style="margin-left:0.5rem;color:var(--text-muted);">·</span>
              <button class="pill" data-filter="past_due" data-target="order_sub">Past Due</button>
              <button class="pill" data-filter="incomplete" data-target="order_sub">Pending</button>
              <button class="pill" data-filter="canceled" data-target="order_sub">Canceled</button>
              <input type="text" class="search-input" id="order-search" placeholder="Search order #, name, email, phone, course, Stripe ID..." />
            </div>
            <div class="table-container">
              <div class="loading-state" id="order-loading"><div class="spinner"></div></div>
              <div class="empty-state" id="order-empty" style="display:none;"><div class="empty-icon">&#x1f4e6;</div>No orders found.</div>
              <table id="order-table" style="display:none;">
                <thead><tr>
                  <th>Status</th><th>Order #</th><th>Customer</th><th>Email</th><th>Phone</th><th>Courses</th><th>Method</th><th>Amount</th><th>Sub</th><th>First Pay</th><th>Date</th>
                </tr></thead>
                <tbody id="order-body"></tbody>
              </table>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- ===== DETAIL DRAWER ===== -->
    <div class="drawer-overlay" id="drawer-overlay"></div>
    <div class="drawer" id="drawer">
      <div class="drawer-header">
        <h2 id="drawer-title">Details</h2>
        <button class="drawer-close" id="drawer-close">
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>
      <div class="drawer-body" id="drawer-body"></div>
    </div>

    <!-- ==================== SCRIPT ==================== -->
    <script is:inline>
      let enquiries = [];
      let orders = [];
      let enqFilter = 'all';
      let ordFilter = 'all';        // status pill (paid/sub_active/failed/all)
      let ordMethodFilter = 'all';  // method pill (card/bacs_debit/all)
      let ordSubFilter = 'all';     // subscription_status pill
      let enqSearch = '';
      let ordSearch = '';
      let currentPage = 'overview';

      // Elements
      const $ = (id) => document.getElementById(id);

      // Auto-load on page open (no auth gate)
      loadAll();

      // Refresh
      $('refresh-btn').addEventListener('click', loadAll);

      // Export
      $('export-btn').addEventListener('click', () => {
        if (currentPage === 'orders') exportOrders();
        else exportEnquiries();
      });

      // Navigation
      function switchPage(page) {
        currentPage = page;
        document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
        $('page-' + page).classList.add('active');
        document.querySelectorAll('.nav-item[data-page]').forEach(b => {
          b.classList.toggle('active', b.dataset.page === page);
        });
        const titles = { overview: 'Overview', enquiries: 'Enquiries', orders: 'Orders & Payments' };
        $('page-title').textContent = titles[page] || page;
      }

      // Data loading
      async function loadAll() {
        loadEnquiries();
        loadOrders();
      }

      async function loadEnquiries() {
        showLoading('enquiry');
        try {
          const res = await fetch('/api/admin/enquiries');
          enquiries = (await res.json()).map(normalizeEnquiry);
          renderAll();
        } catch { showError('enquiry'); }
      }

      async function loadOrders() {
        showLoading('order');
        try {
          const res = await fetch('/api/admin/orders');
          if (res.ok) {
            orders = (await res.json()).map(normalizeOrder);
            renderAll();
          }
        } catch { showError('order'); }
      }

      function showLoading(prefix) {
        const el = $(prefix + '-loading');
        if (el) { el.style.display = 'block'; el.innerHTML = '<div class="spinner"></div>'; }
        const tbl = $(prefix + '-table');
        if (tbl) tbl.style.display = 'none';
        const empty = $(prefix + '-empty');
        if (empty) empty.style.display = 'none';
      }

      function showError(prefix) {
        const el = $(prefix + '-loading');
        if (el) el.innerHTML = '<p style="color:var(--coral);">Failed to load data.</p>';
      }

      // ==================== RENDERING ====================

      function renderAll() {
        renderOverview();
        renderEnquiries();
        renderOrders();
        // Sidebar badges
        const newEnq = enquiries.filter(e => e.status === 'new').length;
        $('sidebar-enq-count').textContent = newEnq || enquiries.length;
        $('sidebar-ord-count').textContent = orders.length;
      }

      function renderOverview() {
        const newEnq = enquiries.filter(e => e.status === 'new').length;
        const isRevenue = (o) => o.status === 'paid' || o.status === 'subscription_active';
        const totalRevenue = orders.filter(isRevenue).reduce((s, o) => s + parseFloat(o.total || 0), 0);
        const paidOrders = orders.filter(isRevenue).length;
        const thisMonth = new Date(); thisMonth.setDate(1); thisMonth.setHours(0,0,0,0);
        const monthEnq = enquiries.filter(e => new Date(e.created_at) >= thisMonth).length;
        const monthOrders = orders.filter(o => new Date(o.created_at) >= thisMonth).length;
        const monthRevenue = orders.filter(o => isRevenue(o) && new Date(o.created_at) >= thisMonth).reduce((s, o) => s + parseFloat(o.total || 0), 0);

        $('overview-stats').innerHTML = `
          <div class="stat-card teal">
            <div class="stat-label">New Enquiries</div>
            <div class="stat-value teal">${newEnq}</div>
            <div class="stat-sub">${enquiries.length} total</div>
          </div>
          <div class="stat-card green">
            <div class="stat-label">Total Revenue</div>
            <div class="stat-value green">&pound;${totalRevenue.toLocaleString('en-GB', {minimumFractionDigits:2, maximumFractionDigits:2})}</div>
            <div class="stat-sub">${paidOrders} paid orders</div>
          </div>
          <div class="stat-card blue">
            <div class="stat-label">This Month Enquiries</div>
            <div class="stat-value blue">${monthEnq}</div>
            <div class="stat-sub">Since ${thisMonth.toLocaleDateString('en-GB',{month:'short',day:'numeric'})}</div>
          </div>
          <div class="stat-card amber">
            <div class="stat-label">This Month Revenue</div>
            <div class="stat-value amber">&pound;${monthRevenue.toLocaleString('en-GB',{minimumFractionDigits:2, maximumFractionDigits:2})}</div>
            <div class="stat-sub">${monthOrders} orders</div>
          </div>
        `;

        // Recent enquiries (last 5)
        const recent5enq = enquiries.slice(0, 5);
        $('overview-enquiries-wrap').innerHTML = recent5enq.length ? `
          <table><thead><tr><th>Status</th><th>Name</th><th>Email</th><th>Course</th><th>Date</th></tr></thead>
          <tbody>${recent5enq.map(e => `
            <tr style="cursor:pointer;" onclick="openEnquiryDrawer(${e.id})">
              <td><span class="badge badge-${e.status}">${e.status}</span></td>
              <td class="td-name">${esc(e.name)}</td>
              <td class="td-email"><a href="mailto:${esc(e.email)}">${esc(e.email)}</a></td>
              <td>${esc(e.course_interest) || '<span style="color:var(--text-muted);">\u2014</span>'}</td>
              <td class="td-date">${fmtDate(e.created_at)}</td>
            </tr>`).join('')}
          </tbody></table>
        ` : '<div class="empty-state">No enquiries yet.</div>';

        // Recent orders (last 5)
        const recent5ord = orders.slice(0, 5);
        $('overview-orders-wrap').innerHTML = recent5ord.length ? `
          <table><thead><tr><th>Status</th><th>Order #</th><th>Customer</th><th>Amount</th><th>Date</th></tr></thead>
          <tbody>${recent5ord.map(o => `
            <tr style="cursor:pointer;" onclick="openOrderDrawer(${o.id})">
              <td><span class="badge badge-${o.status}">${o.status}</span></td>
              <td class="td-mono">${esc(o.order_number)}</td>
              <td class="td-name">${esc(o.customer_name)}</td>
              <td class="td-amount">&pound;${parseFloat(o.total||0).toFixed(2)}</td>
              <td class="td-date">${fmtDate(o.created_at)}</td>
            </tr>`).join('')}
          </tbody></table>
        ` : '<div class="empty-state">No orders yet.</div>';
      }

      function renderEnquiries() {
        const counts = { new: 0, contacted: 0, enrolled: 0, closed: 0 };
        enquiries.forEach(e => { if (counts[e.status] !== undefined) counts[e.status]++; });

        $('enquiry-stats').innerHTML = `
          <div class="stat-card teal"><div class="stat-label">New</div><div class="stat-value teal">${counts.new}</div></div>
          <div class="stat-card blue"><div class="stat-label">Contacted</div><div class="stat-value blue">${counts.contacted}</div></div>
          <div class="stat-card green"><div class="stat-label">Enrolled</div><div class="stat-value green">${counts.enrolled}</div></div>
          <div class="stat-card"><div class="stat-label">Closed</div><div class="stat-value" style="color:var(--text-muted);">${counts.closed}</div></div>
        `;

        // Update pill counts
        document.querySelectorAll('[data-target="enquiry"].pill').forEach(p => {
          const f = p.dataset.filter;
          const c = f === 'all' ? enquiries.length : counts[f] || 0;
          const existing = p.querySelector('.count');
          if (existing) existing.textContent = c;
          else p.innerHTML += ` <span class="count">${c}</span>`;
        });

        let filtered = enqFilter === 'all' ? enquiries : enquiries.filter(e => e.status === enqFilter);
        if (enqSearch) {
          const q = enqSearch.toLowerCase();
          filtered = filtered.filter(e =>
            (e.name||'').toLowerCase().includes(q) ||
            (e.email||'').toLowerCase().includes(q) ||
            (e.course_interest||'').toLowerCase().includes(q) ||
            (e.message||'').toLowerCase().includes(q)
          );
        }

        $('enquiry-loading').style.display = 'none';
        if (!filtered.length) {
          $('enquiry-table').style.display = 'none';
          $('enquiry-empty').style.display = 'block';
          return;
        }
        $('enquiry-empty').style.display = 'none';
        $('enquiry-table').style.display = 'table';

        $('enquiry-body').innerHTML = filtered.map(e => `
          <tr style="cursor:pointer;" onclick="openEnquiryDrawer(${e.id})">
            <td class="status-cell" onclick="event.stopPropagation();">
              <span class="badge badge-${e.status}" onclick="toggleDrop('enq-${e.id}')">${e.status}</span>
              <div class="status-dropdown" id="drop-enq-${e.id}">
                ${['new','contacted','enrolled','closed'].map(s => `<div class="status-option" onclick="updateEnqStatus(${e.id},'${s}')">${s}</div>`).join('')}
              </div>
            </td>
            <td class="td-name">${esc(e.name)}</td>
            <td class="td-email"><a href="mailto:${esc(e.email)}" onclick="event.stopPropagation();">${esc(e.email)}</a></td>
            <td class="td-phone">${e.phone ? `<a href="tel:${esc(e.phone)}" onclick="event.stopPropagation();">${esc(e.phone)}</a>` : '<span style="color:var(--text-muted);">\u2014</span>'}</td>
            <td>${esc(e.course_interest) || '<span style="color:var(--text-muted);">\u2014</span>'}</td>
            <td class="td-message" title="${esc(e.message||'')}">${esc(e.message) || '<span style="color:var(--text-muted);">\u2014</span>'}</td>
            <td class="td-page">${esc(e.page) || '\u2014'}</td>
            <td class="td-date">${fmtDate(e.created_at)}</td>
          </tr>
        `).join('');
      }

      function renderOrders() {
        const counts = { paid: 0, subscription_active: 0, failed: 0 };
        let totalRev = 0;
        orders.forEach(o => {
          if (counts[o.status] !== undefined) counts[o.status]++;
          if (o.status === 'paid' || o.status === 'subscription_active') totalRev += parseFloat(o.total || 0);
        });

        $('order-stats').innerHTML = `
          <div class="stat-card green"><div class="stat-label">Paid (One-time)</div><div class="stat-value green">${counts.paid}</div></div>
          <div class="stat-card purple"><div class="stat-label">Subscriptions</div><div class="stat-value purple">${counts.subscription_active}</div></div>
          <div class="stat-card coral"><div class="stat-label">Failed</div><div class="stat-value coral">${counts.failed}</div></div>
          <div class="stat-card green"><div class="stat-label">Total Revenue</div><div class="stat-value green">&pound;${totalRev.toLocaleString('en-GB',{minimumFractionDigits:2,maximumFractionDigits:2})}</div></div>
        `;

        document.querySelectorAll('[data-target="order"].pill').forEach(p => {
          const f = p.dataset.filter;
          const c = f === 'all' ? orders.length : counts[f] || 0;
          const existing = p.querySelector('.count');
          if (existing) existing.textContent = c;
          else p.innerHTML += ` <span class="count">${c}</span>`;
        });

        let filtered = ordFilter === 'all' ? orders : orders.filter(o => o.status === ordFilter);
        if (ordMethodFilter !== 'all') filtered = filtered.filter(o => (o.payment_method || (o.payment_type === 'monthly' ? '' : 'card')) === ordMethodFilter);
        if (ordSubFilter !== 'all') filtered = filtered.filter(o => o.subscription_status === ordSubFilter);
        if (ordSearch) {
          const q = ordSearch.toLowerCase();
          filtered = filtered.filter(o =>
            (o.order_number||'').toLowerCase().includes(q) ||
            (o.customer_name||'').toLowerCase().includes(q) ||
            (o.customer_email||'').toLowerCase().includes(q) ||
            (o.customer_phone||'').toLowerCase().includes(q) ||
            (o.courses||'').toLowerCase().includes(q) ||
            (o.course_ids||'').toLowerCase().includes(q) ||
            (o.stripe_payment_id||'').toLowerCase().includes(q) ||
            (o.stripe_subscription_id||'').toLowerCase().includes(q) ||
            (o.stripe_customer_id||'').toLowerCase().includes(q) ||
            (o.stripe_mandate_id||'').toLowerCase().includes(q)
          );
        }

        $('order-loading').style.display = 'none';
        if (!filtered.length) {
          $('order-table').style.display = 'none';
          $('order-empty').style.display = 'block';
          return;
        }
        $('order-empty').style.display = 'none';
        $('order-table').style.display = 'table';

        $('order-body').innerHTML = filtered.map(o => `
          <tr style="cursor:pointer;" onclick="openOrderDrawer(${o.id})">
            <td class="status-cell" onclick="event.stopPropagation();">
              <span class="badge badge-${o.status}" onclick="toggleDrop('ord-${o.id}')">${o.status}</span>
              <div class="status-dropdown" id="drop-ord-${o.id}">
                ${['paid','subscription_active','failed'].map(s => `<div class="status-option" onclick="updateOrdStatus(${o.id},'${s}')">${s}</div>`).join('')}
              </div>
            </td>
            <td class="td-mono">${esc(o.order_number)}</td>
            <td class="td-name">${esc(o.customer_name)}</td>
            <td class="td-email"><a href="mailto:${esc(o.customer_email)}" onclick="event.stopPropagation();">${esc(o.customer_email)}</a></td>
            <td class="td-phone">${o.customer_phone ? `<a href="tel:${esc(o.customer_phone)}" onclick="event.stopPropagation();">${esc(o.customer_phone)}</a>` : '\u2014'}</td>
            <td class="td-courses" title="${esc(o.courses||'')}">${esc(o.courses) || '\u2014'}</td>
            <td>${methodBadge(o)}</td>
            <td class="td-amount">${amountCell(o)}</td>
            <td>${subStatusBadge(o)}</td>
            <td class="td-date">${o.first_payment_date ? fmtDate(o.first_payment_date) : '\u2014'}</td>
            <td class="td-date">${fmtDate(o.created_at)}</td>
          </tr>
        `).join('');
      }

      // ==================== ORDER ROW CELL HELPERS ====================
      function methodBadge(o) {
        const m = o.payment_method;
        if (m === 'bacs_debit') return '<span class="badge" style="background:rgba(96,165,250,0.12);color:var(--blue);"><svg style="width:7px;height:7px;border-radius:50%;background:var(--blue);margin-right:6px;"></svg>BACS</span>';
        if (m === 'card') return '<span class="badge" style="background:rgba(167,139,250,0.12);color:var(--purple);"><svg style="width:7px;height:7px;border-radius:50%;background:var(--purple);margin-right:6px;"></svg>Card</span>';
        // one-time card (legacy / new) \u2014 no payment_method set
        return o.payment_type === 'monthly'
          ? '<span class="badge" style="background:var(--bg-hover);color:var(--text-muted);">\u2014</span>'
          : '<span class="badge" style="background:rgba(167,139,250,0.12);color:var(--purple);">Card</span>';
      }
      function amountCell(o) {
        const total = parseFloat(o.total||0).toFixed(2);
        if (o.payment_type === 'monthly' && o.monthly_amount) {
          const inst = parseFloat(o.monthly_amount).toFixed(2);
          return `&pound;${total}<div class="td-sub" style="font-size:0.7rem;color:var(--text-muted);font-weight:400;">\u00a320 reg + 12 \u00d7 \u00a3${inst}</div>`;
        }
        return `&pound;${total}`;
      }
      function subStatusBadge(o) {
        if (!o.subscription_status) return '<span style="color:var(--text-muted);">\u2014</span>';
        const s = o.subscription_status;
        // Active = green soft; past_due = amber; canceled/incomplete = coral/muted
        const styles = {
          active:              'background:var(--green-soft);color:var(--green);',
          past_due:            'background:var(--amber-soft);color:var(--amber);',
          incomplete:          'background:rgba(96,165,250,0.12);color:var(--blue);',
          incomplete_expired:  'background:rgba(90,98,120,0.15);color:var(--text-muted);',
          canceled:            'background:var(--coral-soft);color:var(--coral);',
          unpaid:              'background:var(--coral-soft);color:var(--coral);',
          paused:              'background:rgba(90,98,120,0.15);color:var(--text-muted);',
          trialing:            'background:var(--accent-soft);color:var(--accent-text);',
        };
        const style = styles[s] || 'background:var(--bg-hover);color:var(--text-muted);';
        return `<span class="badge" style="${style}">${esc(s)}</span>`;
      }

      // ==================== FILTERS & SEARCH ====================
      document.addEventListener('click', (e) => {
        const pill = e.target.closest('.pill');
        if (pill) {
          const target = pill.dataset.target;
          const filter = pill.dataset.filter;
          // Only deactivate pills in the SAME group (target), not all pills in the toolbar
          pill.parentElement.querySelectorAll(`.pill[data-target="${target}"]`).forEach(p => p.classList.remove('active'));
          pill.classList.add('active');
          if (target === 'enquiry') { enqFilter = filter; renderEnquiries(); }
          else if (target === 'order') { ordFilter = filter; renderOrders(); }
          else if (target === 'order_method') {
            // Toggle: clicking the same active pill clears the filter
            ordMethodFilter = (ordMethodFilter === filter) ? 'all' : filter;
            if (ordMethodFilter === 'all') pill.classList.remove('active');
            renderOrders();
          }
          else if (target === 'order_sub') {
            ordSubFilter = (ordSubFilter === filter) ? 'all' : filter;
            if (ordSubFilter === 'all') pill.classList.remove('active');
            renderOrders();
          }
        }
        // Close dropdowns
        if (!e.target.classList.contains('badge')) {
          document.querySelectorAll('.status-dropdown.open').forEach(d => d.classList.remove('open'));
        }
      });

      $('enquiry-search').addEventListener('input', (e) => { enqSearch = e.target.value; renderEnquiries(); });
      $('order-search').addEventListener('input', (e) => { ordSearch = e.target.value; renderOrders(); });

      // ==================== STATUS UPDATES ====================
      function toggleDrop(id) {
        document.querySelectorAll('.status-dropdown.open').forEach(d => d.classList.remove('open'));
        const dd = $('drop-' + id);
        if (dd) dd.classList.toggle('open');
      }

      async function updateEnqStatus(id, status) {
        document.querySelectorAll('.status-dropdown.open').forEach(d => d.classList.remove('open'));
        try {
          const res = await fetch('/api/admin/enquiries', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, status }),
          });
          if (res.ok) {
            const item = enquiries.find(e => e.id === id);
            if (item) item.status = status;
            renderAll();
          }
        } catch {}
      }

      async function updateOrdStatus(id, status) {
        document.querySelectorAll('.status-dropdown.open').forEach(d => d.classList.remove('open'));
        const item = orders.find(o => o.id === id);
        if (!item) return;
        // Confirm — this is an admin-only label change. Refunds/cancellations
        // are handled by the payments team via Stripe dashboard, not here.
        const msg = `Change ${item.order_number} status from "${item.status}" to "${status}"?\n\n` +
          `This only updates our records.\n` +
          `It does NOT refund the customer, cancel the Stripe subscription, or send any email.\n\n` +
          `For refunds or cancellations, use the Stripe dashboard.`;
        if (!confirm(msg)) return;
        try {
          const res = await fetch('/api/admin/orders', {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, status }),
          });
          if (res.ok) {
            item.status = status;
            renderAll();
          } else {
            alert('Failed to update status: ' + (await res.text()));
          }
        } catch (err) {
          alert('Network error updating status. Please refresh and try again.');
        }
      }

      // ==================== DETAIL DRAWER ====================
      const overlay = $('drawer-overlay');
      const drawer = $('drawer');

      function openDrawer() { overlay.classList.add('open'); drawer.classList.add('open'); }
      function closeDrawer() { overlay.classList.remove('open'); drawer.classList.remove('open'); }
      overlay.addEventListener('click', closeDrawer);
      $('drawer-close').addEventListener('click', closeDrawer);
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeDrawer(); });

      function openEnquiryDrawer(id) {
        const e = enquiries.find(x => x.id === id);
        if (!e) return;
        $('drawer-title').textContent = 'Enquiry Details';
        $('drawer-body').innerHTML = `
          <div class="detail-group">
            <div class="detail-group-title">Contact Info</div>
            <div class="detail-row"><span class="detail-label">Name</span><span class="detail-value">${esc(e.name)}</span></div>
            <div class="detail-row"><span class="detail-label">Email</span><span class="detail-value"><a href="mailto:${esc(e.email)}">${esc(e.email)}</a></span></div>
            <div class="detail-row"><span class="detail-label">Phone</span><span class="detail-value">${e.phone ? `<a href="tel:${esc(e.phone)}">${esc(e.phone)}</a>` : '\u2014'}</span></div>
          </div>
          <div class="detail-group">
            <div class="detail-group-title">Enquiry</div>
            <div class="detail-row"><span class="detail-label">Status</span><span class="detail-value"><span class="badge badge-${e.status}">${e.status}</span></span></div>
            <div class="detail-row"><span class="detail-label">Course Interest</span><span class="detail-value">${esc(e.course_interest) || '\u2014'}</span></div>
            <div class="detail-row"><span class="detail-label">Source Page</span><span class="detail-value">${esc(e.page) || '\u2014'}</span></div>
            ${e.utm_source ? `<div class="detail-row"><span class="detail-label">UTM Source</span><span class="detail-value">${esc(e.utm_source)}</span></div>` : ''}
            ${e.utm_campaign ? `<div class="detail-row"><span class="detail-label">UTM Campaign</span><span class="detail-value">${esc(e.utm_campaign)}</span></div>` : ''}
            <div class="detail-row"><span class="detail-label">Received</span><span class="detail-value">${fmtDateFull(e.created_at)}</span></div>
          </div>
          ${e.message ? `<div class="detail-group"><div class="detail-group-title">Message</div><div class="detail-message">${esc(e.message)}</div></div>` : ''}
        `;
        openDrawer();
      }

      function openOrderDrawer(id) {
        const o = orders.find(x => x.id === id);
        if (!o) return;
        $('drawer-title').textContent = 'Order Details';
        const isMonthly = o.payment_type === 'monthly';
        const stripeLink = (kind, id) => id
          ? `<a href="https://dashboard.stripe.com/${kind}/${esc(id)}" target="_blank" rel="noopener" style="color:var(--accent-text);font-family:var(--mono);font-size:0.75rem;text-decoration:none;">${esc(id)} \u2197</a>`
          : '\u2014';
        $('drawer-body').innerHTML = `
          <div class="detail-group">
            <div class="detail-group-title">Order Info</div>
            <div class="detail-row"><span class="detail-label">Order Number</span><span class="detail-value" style="font-family:var(--mono);">${esc(o.order_number)}</span></div>
            <div class="detail-row"><span class="detail-label">Status</span><span class="detail-value"><span class="badge badge-${esc(o.status)}">${esc(o.status)}</span></span></div>
            <div class="detail-row"><span class="detail-label">Payment Type</span><span class="detail-value">${esc((o.payment_type||'one_time').replace('_',' '))}</span></div>
            <div class="detail-row"><span class="detail-label">Method</span><span class="detail-value">${methodBadge(o)}</span></div>
            <div class="detail-row"><span class="detail-label">Total</span><span class="detail-value" style="font-size:1.125rem;font-weight:700;color:var(--green);">&pound;${parseFloat(o.total||0).toFixed(2)}</span></div>
            <div class="detail-row"><span class="detail-label">Created</span><span class="detail-value">${fmtDateFull(o.created_at)}</span></div>
          </div>
          ${isMonthly ? `
          <div class="detail-group">
            <div class="detail-group-title">Installment Plan</div>
            <div class="detail-row"><span class="detail-label">Registration Fee</span><span class="detail-value">${o.registration_fee != null ? '&pound;' + parseFloat(o.registration_fee).toFixed(2) : '\u2014'}</span></div>
            <div class="detail-row"><span class="detail-label">Monthly Installment</span><span class="detail-value">${o.monthly_amount != null ? '&pound;' + parseFloat(o.monthly_amount).toFixed(2) + '/mo' : '\u2014'}</span></div>
            <div class="detail-row"><span class="detail-label">Number of Installments</span><span class="detail-value">${o.subscription_months || 12}</span></div>
            <div class="detail-row"><span class="detail-label">First Payment Date</span><span class="detail-value">${o.first_payment_date ? fmtDate(o.first_payment_date) : '\u2014'}</span></div>
            <div class="detail-row"><span class="detail-label">Subscription Status</span><span class="detail-value">${subStatusBadge(o)}</span></div>
          </div>` : ''}
          <div class="detail-group">
            <div class="detail-group-title">Customer</div>
            <div class="detail-row"><span class="detail-label">Name</span><span class="detail-value">${esc(o.customer_name)}</span></div>
            <div class="detail-row"><span class="detail-label">Email</span><span class="detail-value"><a href="mailto:${esc(o.customer_email)}">${esc(o.customer_email)}</a></span></div>
            <div class="detail-row"><span class="detail-label">Phone</span><span class="detail-value">${o.customer_phone ? `<a href="tel:${esc(o.customer_phone)}">${esc(o.customer_phone)}</a>` : '\u2014'}</span></div>
          </div>
          <div class="detail-group">
            <div class="detail-group-title">Courses</div>
            <div class="detail-message">${esc(o.courses) || '\u2014'}</div>
            ${o.course_ids ? `<div style="font-family:var(--mono);font-size:0.7rem;color:var(--text-muted);margin-top:0.5rem;">IDs: ${esc(o.course_ids)}</div>` : ''}
          </div>
          ${o.terms_accepted_at ? `<div class="detail-group"><div class="detail-group-title">Terms</div><div class="detail-row"><span class="detail-label">Accepted</span><span class="detail-value">${fmtDateFull(o.terms_accepted_at)}</span></div></div>` : ''}
          <div class="detail-group">
            <div class="detail-group-title">Stripe (click to open in dashboard)</div>
            ${o.stripe_customer_id ? `<div class="detail-row"><span class="detail-label">Customer</span><span class="detail-value">${stripeLink('customers', o.stripe_customer_id)}</span></div>` : ''}
            ${o.stripe_subscription_id ? `<div class="detail-row"><span class="detail-label">Subscription</span><span class="detail-value">${stripeLink('subscriptions', o.stripe_subscription_id)}</span></div>` : ''}
            ${o.stripe_payment_id ? `<div class="detail-row"><span class="detail-label">${o.stripe_payment_id.startsWith('in_') ? 'Invoice' : 'PaymentIntent'}</span><span class="detail-value">${stripeLink(o.stripe_payment_id.startsWith('in_') ? 'invoices' : 'payments', o.stripe_payment_id)}</span></div>` : ''}
            ${o.stripe_mandate_id ? `<div class="detail-row"><span class="detail-label">BACS Mandate</span><span class="detail-value" style="font-family:var(--mono);font-size:0.75rem;">${esc(o.stripe_mandate_id)}</span></div>` : ''}
            ${!o.stripe_customer_id && !o.stripe_subscription_id && !o.stripe_payment_id ? '<div style="color:var(--text-muted);font-size:0.8rem;">No Stripe references on this order.</div>' : ''}
          </div>
          <div class="detail-group">
            <div class="detail-group-title" style="color:var(--amber);">Note for ops</div>
            <p style="font-size:0.75rem;color:var(--text-secondary);line-height:1.5;">
              Changing the status here only updates our database \u2014 it does NOT issue refunds, cancel Stripe subscriptions, or send emails. Refunds and cancellations are handled by the payments team in their own system. Use the Stripe links above to inspect or take action.
            </p>
          </div>
        `;
        openDrawer();
      }

      // ==================== CSV EXPORT ====================
      function exportEnquiries() {
        if (!enquiries.length) return;
        const h = ['Name','Email','Phone','Course Interest','Message','Page','Status','UTM Source','UTM Campaign','Date (UTC)'];
        const rows = enquiries.map(e => [e.name,e.email,e.phone||'',e.course_interest||'',e.message||'',e.page||'',e.status,e.utm_source||'',e.utm_campaign||'',e.created_at||'']);
        downloadCSV('enquiries', h, rows);
      }

      function exportOrders() {
        if (!orders.length) return;
        const h = [
          'Order #','Customer','Email','Phone','Courses','Course IDs',
          'Total (£)','Payment Type','Payment Method',
          'Registration Fee','Monthly Amount','Months','First Payment Date',
          'Status','Subscription Status',
          'Stripe Customer ID','Stripe Subscription ID','Stripe Payment ID','Stripe Mandate ID',
          'Terms Accepted (UTC)','Created (UTC)',
        ];
        const rows = orders.map(o => [
          o.order_number, o.customer_name, o.customer_email, o.customer_phone||'',
          o.courses||'', o.course_ids||'',
          o.total ?? '', o.payment_type||'one_time', o.payment_method||'',
          o.registration_fee ?? '', o.monthly_amount ?? '', o.subscription_months ?? '', o.first_payment_date||'',
          o.status, o.subscription_status||'',
          o.stripe_customer_id||'', o.stripe_subscription_id||'', o.stripe_payment_id||'', o.stripe_mandate_id||'',
          o.terms_accepted_at||'', o.created_at||'',
        ]);
        downloadCSV('orders', h, rows);
      }

      function csvEscape(v) {
        const s = v == null ? '' : String(v);
        // RFC 4180: wrap in quotes, double-escape internal quotes, preserve commas/newlines.
        return '"' + s.replace(/"/g, '""') + '"';
      }

      function downloadCSV(name, headers, rows) {
        // BOM so Excel on Windows recognises UTF-8 (renders £ correctly).
        // CRLF line endings per RFC 4180.
        const csv = '﻿' + [
          headers.map(csvEscape).join(','),
          ...rows.map(r => r.map(csvEscape).join(',')),
        ].join('\r\n');
        const blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url; a.download = `${name}-${new Date().toISOString().slice(0,10)}.csv`;
        a.click(); URL.revokeObjectURL(url);
      }

      // ==================== NORMALIZE ====================
      function normalizeEnquiry(e) {
        if (!e.status || !['new','contacted','enrolled','closed'].includes(e.status)) e.status = 'new';
        return e;
      }
      function normalizeOrder(o) {
        // Don't silently rewrite unknown statuses to 'failed' — that hides data anomalies.
        // Leave the raw value; the badge renderer will show it as "unknown" if it isn't
        // one of paid/subscription_active/failed. ops can then investigate.
        if (!o.status) o.status = 'failed';
        if (!o.payment_type) o.payment_type = 'one_time';
        return o;
      }

      // ==================== HELPERS ====================
      function esc(s) { if (!s) return ''; const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }

      // Dates render in UK time (Europe/London) so admin sees what the customer's bank
      // statement / email will show, regardless of which timezone the admin's browser is in.
      const UK_DATE_OPTS = { day: '2-digit', month: 'short', year: 'numeric', timeZone: 'Europe/London' };
      const UK_DATETIME_OPTS = { day: '2-digit', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit', timeZone: 'Europe/London' };

      function fmtDate(iso) {
        if (!iso) return '\u2014';
        try { return new Date(iso).toLocaleDateString('en-GB', UK_DATE_OPTS); } catch { return iso; }
      }

      function fmtDateFull(iso) {
        if (!iso) return '\u2014';
        try { return new Date(iso).toLocaleString('en-GB', UK_DATETIME_OPTS) + ' UK'; } catch { return iso; }
      }
    </script>
  </body>
</html>
