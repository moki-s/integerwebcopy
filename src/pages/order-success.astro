---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Order Confirmed | Integer Training"
  description="Your course enrolment is confirmed. Welcome to Integer Training."
>
  <!-- Step Indicator -->
  <div class="bg-white border-b border-neutral-100">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <div class="flex items-center justify-between">
        <!-- Step 1: Basket -->
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-green-500 text-white flex items-center justify-center text-sm font-bold">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
          </div>
          <span class="hidden sm:inline text-sm font-medium text-green-600">Basket</span>
        </div>
        <div class="flex-1 h-0.5 bg-green-500 mx-2 sm:mx-4"></div>
        <!-- Step 2: Details -->
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-green-500 text-white flex items-center justify-center text-sm font-bold">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
          </div>
          <span class="hidden sm:inline text-sm font-medium text-green-600">Details</span>
        </div>
        <div class="flex-1 h-0.5 bg-green-500 mx-2 sm:mx-4"></div>
        <!-- Step 3: Payment -->
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-green-500 text-white flex items-center justify-center text-sm font-bold">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
          </div>
          <span class="hidden sm:inline text-sm font-medium text-green-600">Payment</span>
        </div>
        <div class="flex-1 h-0.5 bg-green-500 mx-2 sm:mx-4"></div>
        <!-- Step 4: Complete (active) -->
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-full bg-green-500 text-white flex items-center justify-center text-sm font-bold ring-4 ring-green-100">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
          </div>
          <span class="hidden sm:inline text-sm font-bold text-green-700">Complete</span>
        </div>
      </div>
    </div>
  </div>

  <section class="py-16 lg:py-24">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <!-- Success checkmark -->
      <div class="w-20 h-20 rounded-full bg-gradient-to-br from-green-400 to-green-500 mx-auto mb-6 flex items-center justify-center shadow-lg animate-bounce-once">
        <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
      </div>

      <h1 class="font-display font-bold text-3xl md:text-4xl text-neutral-900 mb-2">Order Confirmed!</h1>

      <!-- Order number -->
      <p id="order-number-display" class="text-lg text-neutral-500 mb-2 font-mono font-semibold"></p>

      <!-- Thank you message -->
      <p id="thank-you-msg" class="text-lg text-neutral-600 mb-1"></p>

      <!-- Email confirmation -->
      <p id="email-confirm-msg" class="text-sm text-neutral-500 mb-8"></p>

      <!-- Payment info card -->
      <div id="order-details" class="bg-white rounded-2xl p-6 text-left mb-6 border border-neutral-100 shadow-brand-sm">
        <!-- One-time payment info -->
        <div id="onetime-info" class="hidden">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
            </div>
            <div>
              <p class="text-sm text-neutral-500 font-medium">Payment Received</p>
              <p id="onetime-total" class="text-lg font-bold text-neutral-900"></p>
            </div>
          </div>
        </div>

        <!-- Monthly plan info (card OR DD — same shape, different wording) -->
        <div id="monthly-info" class="hidden">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-xl bg-green-50 flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </div>
            <div>
              <p class="text-sm text-neutral-500 font-medium" id="monthly-info-heading">Monthly plan set up</p>
              <p id="monthly-total-amount" class="text-lg font-bold text-neutral-900"></p>
            </div>
          </div>
          <div class="bg-green-50/50 rounded-xl p-4 mb-3 space-y-2">
            <p class="text-sm text-neutral-700"><strong>Today:</strong> <span id="monthly-today-line"></span></p>
            <p class="text-sm text-neutral-700"><strong>First installment:</strong> <span id="monthly-first-date" class="font-semibold"></span> &mdash; <span id="monthly-installment-amount"></span></p>
            <p class="text-sm text-neutral-700"><strong>After that:</strong> 11 more monthly installments on the same date.</p>
            <p id="monthly-bacs-note" class="hidden text-xs text-neutral-500 pt-2 border-t border-green-100">Your bank's Direct Debit Guarantee applies. Allow 3–5 working days for each collection to clear — you'll receive separate emails from Stripe.</p>
          </div>
        </div>

        <!-- Enrolled courses (shared) -->
        <div class="mt-4 pt-4 border-t border-neutral-100">
          <p class="text-sm font-semibold text-neutral-900 mb-3 flex items-center gap-2">
            <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
            Enrolled Courses
          </p>
          <ul id="order-courses" class="space-y-2"></ul>
        </div>
      </div>

      <!-- Next Steps -->
      <div class="bg-primary-50 rounded-2xl p-6 mb-8 text-left">
        <h3 class="font-display font-bold text-neutral-900 mb-4 flex items-center gap-2">
          <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>
          Next Steps
        </h3>
        <ol class="space-y-3">
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-white text-primary-600 flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5 border border-primary-200">1</span>
            <span class="text-sm text-neutral-700">Our admin team will call you within 24 hours to complete your enrolment procedures</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-white text-primary-600 flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5 border border-primary-200">2</span>
            <span class="text-sm text-neutral-700">Once the procedures are complete, you'll receive your login credentials by email</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="w-6 h-6 rounded-full bg-white text-primary-600 flex items-center justify-center text-xs font-bold flex-shrink-0 mt-0.5 border border-primary-200">3</span>
            <span class="text-sm text-neutral-700">Your dedicated tutor will then be in touch to start your course</span>
          </li>
        </ol>
      </div>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/courses" class="inline-flex items-center justify-center gap-2 bg-gradient-to-r from-primary-500 to-primary-600 text-white px-6 py-3 rounded-xl font-semibold shadow-brand hover:shadow-brand-lg hover:-translate-y-0.5 transition-all duration-300">
          Browse More Courses
        </a>
        <a href="/contact" class="inline-flex items-center justify-center gap-2 bg-white text-neutral-700 px-6 py-3 rounded-xl font-semibold border border-neutral-200 hover:border-primary-200 hover:text-primary-600 transition-all duration-300">
          Contact Support
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  @keyframes bounce-once {
    0% { transform: scale(0); opacity: 0; }
    50% { transform: scale(1.15); }
    70% { transform: scale(0.95); }
    100% { transform: scale(1); opacity: 1; }
  }
  .animate-bounce-once {
    animation: bounce-once 0.6s ease-out forwards;
  }
</style>

<script>
  document.addEventListener('astro:page-load', async () => {
    // Promote pending_dd_order → last_order if customer just returned from Stripe with session_id
    const urlParams = new URLSearchParams(window.location.search);
    const sessionId = urlParams.get('session_id');
    if (sessionId) {
      const pending = sessionStorage.getItem('pending_dd_order');
      if (pending) {
        sessionStorage.setItem('last_order', pending);
        sessionStorage.removeItem('pending_dd_order');
        // Now safe to clear the cart — payment flow really completed
        try {
          const { clearCart } = await import('../lib/cart');
          clearCart();
        } catch {}
      }
    }

    const raw = sessionStorage.getItem('last_order');
    if (!raw) {
      window.location.href = '/courses';
      return;
    }

    try {
      const order = JSON.parse(raw);

      // Order number
      const orderNumEl = document.getElementById('order-number-display');
      if (orderNumEl) {
        orderNumEl.textContent = `Order #${order.order_number || 'N/A'}`;
      }

      // Thank you message
      const thankEl = document.getElementById('thank-you-msg');
      if (thankEl && order.customer_name) {
        thankEl.textContent = `Thank you, ${order.customer_name}!`;
      }

      // Email confirmation
      const emailEl = document.getElementById('email-confirm-msg');
      if (emailEl && order.customer_email) {
        emailEl.textContent = `A confirmation email has been sent to ${order.customer_email}`;
      }

      // Determine payment type / method
      const isSubscription = order.payment_type === 'monthly';
      const isDD = isSubscription && order.payment_method === 'bacs_debit';

      if (isSubscription) {
        // Unified monthly display \u2014 card or DD, both = \u00A320 reg + 12 installments
        const monthlyInfo = document.getElementById('monthly-info');
        if (monthlyInfo) monthlyInfo.classList.remove('hidden');

        const heading = document.getElementById('monthly-info-heading');
        if (heading) {
          heading.textContent = isDD ? 'Direct Debit plan set up' : 'Monthly card plan set up';
        }

        const totalAmountEl = document.getElementById('monthly-total-amount');
        if (totalAmountEl) {
          const total = 20 + (Number(order.monthly_amount) * 12);
          totalAmountEl.textContent = `\u00A3${total.toFixed(2)} across 13 payments`;
        }

        const todayLineEl = document.getElementById('monthly-today-line');
        if (todayLineEl) {
          todayLineEl.textContent = isDD
            ? '\u00A320.00 registration fee submitted via Direct Debit (settles in 3\u20135 working days)'
            : '\u00A320.00 registration fee charged to your card';
        }

        const firstDateEl = document.getElementById('monthly-first-date');
        if (firstDateEl && order.first_payment_date) {
          const d = new Date(order.first_payment_date + 'T00:00:00');
          firstDateEl.textContent = d.toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
        }

        const installmentEl = document.getElementById('monthly-installment-amount');
        if (installmentEl && order.monthly_amount) {
          installmentEl.textContent = `\u00A3${Number(order.monthly_amount).toFixed(2)}`;
        }

        const bacsNoteEl = document.getElementById('monthly-bacs-note');
        if (bacsNoteEl && isDD) bacsNoteEl.classList.remove('hidden');
      } else {
        // One-time payment display
        const oneInfo = document.getElementById('onetime-info');
        if (oneInfo) oneInfo.classList.remove('hidden');

        const totalEl = document.getElementById('onetime-total');
        if (totalEl) {
          totalEl.textContent = `Payment of \u00A3${Number(order.total).toFixed(2)} received`;
        }
      }

      // Courses list
      const coursesList = document.getElementById('order-courses');
      if (coursesList && order.courses && Array.isArray(order.courses)) {
        coursesList.innerHTML = order.courses
          .map(
            (c: string) => `
            <li class="flex items-center gap-3 bg-white rounded-xl px-4 py-3 border border-neutral-100">
              <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" /></svg>
              <span class="text-sm text-neutral-700 font-medium">${c}</span>
            </li>`
          )
          .join('');
      }

      // Intentionally NOT deleting `last_order` from sessionStorage so that a
      // page refresh keeps the receipt view available. The data is tab-scoped
      // and only matters until the customer closes the tab — at which point
      // the email is their source of truth. (G1 fix)
    } catch {
      window.location.href = '/courses';
    }
  });
</script>
