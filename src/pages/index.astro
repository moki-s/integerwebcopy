---
import BaseLayout from '../layouts/BaseLayout.astro';
import GradientMesh from '../components/GradientMesh.astro';
import Testimonials from '../components/Testimonials.astro';
import FAQ from '../components/FAQ.astro';
import LocalBusinessSchema from '../components/schemas/LocalBusinessSchema.astro';
import WebSiteSchema from '../components/schemas/WebSiteSchema.astro';
import { siteConfig } from '../data/site-config';

const serviceImages: Record<string, { thumbnail: string; thumbnailAlt: string }> = {
  'health-social-care': { thumbnail: '/images/courses/health-social/hs-thumb.webp', thumbnailAlt: 'Care worker supporting elderly resident in UK care home' },
  'accounting': { thumbnail: '/images/courses/accounting/acc-thumb.webp', thumbnailAlt: 'Student studying AAT accounting course with financial documents' },
  'occupational-studies': { thumbnail: '/images/courses/occupational/occ-thumb.webp', thumbnailAlt: 'Professional completing workplace skills training online' },
  'functional-skills': { thumbnail: '/images/courses/functional-skills/func-thumb.webp', thumbnailAlt: 'Adult learner studying Functional Skills Maths on tablet device' },
  'security-stewarding': { thumbnail: '/images/courses/security/sec-thumb.webp', thumbnailAlt: 'Door supervisor in high-visibility vest at venue entrance' },
  'business-management': { thumbnail: '/images/courses/business/bus-thumb.webp', thumbnailAlt: 'Team leader facilitating a workplace meeting with colleagues' },
  'digital-technology': { thumbnail: '/images/courses/digital-technology/dt-thumb.jpg', thumbnailAlt: 'Cyber security professional monitoring network security dashboards' },
  'teaching-qualification': { thumbnail: '/images/courses/teaching/teach-thumb.jpg', thumbnailAlt: 'Teacher leading a classroom session with adult learners' },
  'access-to-he': { thumbnail: '/images/courses/access-to-he/access-thumb.jpg', thumbnailAlt: 'Mature student studying online Access to HE course on laptop' },
};

const coursePricing: Record<string, string> = {
  'health-social-care': '£35',
  'accounting': '£25',
  'occupational-studies': '£20',
  'functional-skills': '£20',
  'security-stewarding': '£30',
  'business-management': '£25',
};

const homepageFAQs = [
  {
    question: 'How does online learning work at Integer Training?',
    answer: 'Once you enrol, you\'ll receive login details for our online learning platform within 24 hours. All course materials, assignments, and resources are available 24/7 -- you study at your own pace from any device. Your assigned tutor provides 1-to-1 support via phone, email, and video call throughout your course. You submit assignments online and receive detailed feedback to help you progress.',
  },
  {
    question: 'Are your qualifications genuinely recognised by employers?',
    answer: 'Yes. Every Integer Training course is accredited by a nationally recognised awarding body such as NCFE, AAT, HABC, and Pearson. These are the same Ofqual-regulated qualifications delivered in colleges and universities across the UK. Employers, the NHS, local authorities, and professional bodies all recognise them equally.',
  },
  {
    question: 'Can I spread the cost of my course?',
    answer: 'Absolutely. We offer interest-free payment plans on all courses with no credit checks and no hidden fees. You\'ll agree a fixed monthly amount before you start, and that\'s exactly what you pay. Contact our team on 0121 690 9563 to discuss a plan that suits your budget.',
  },
  {
    question: 'How long do courses take to complete?',
    answer: 'Completion times vary by course and level. Most Level 2 certificates take 3-6 months, while Level 4-5 diplomas may take 12-18 months. Because our courses are self-paced, motivated learners often finish ahead of schedule. Your tutor will help you set a realistic study plan based on the hours you can commit each week.',
  },
  {
    question: 'Do I need any prior qualifications to enrol?',
    answer: 'Entry requirements vary by course level. Our Level 1 and Level 2 courses have no formal entry requirements -- they\'re designed for beginners. Higher-level courses (Level 3-5) may ask for relevant prior learning or work experience. Contact our admissions team and we\'ll advise you on the best starting point for your goals.',
  },
];

---

<BaseLayout
  title="Accredited Online Courses UK | Integer Training"
  description="Accredited online courses in healthcare, accounting, and security from Integer Training. 25+ years, 93% pass rate, interest-free payments. Enrol today."
>
  <LocalBusinessSchema />
  <WebSiteSchema />

  <!-- ========== TRUSTPILOT + PROMO BAR ========== -->
  <div class="bg-neutral-900 text-white py-2.5 border-b border-neutral-800">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-wrap items-center justify-center gap-x-3 sm:gap-x-6 gap-y-1 text-xs sm:text-sm">
      <div class="flex items-center gap-2">
        <span class="text-neutral-400 hidden sm:inline">Rated</span>
        <span class="font-bold text-green-400">Excellent</span>
        <div class="flex items-center gap-0.5">
          {[1,2,3,4].map(() => (
            <svg viewBox="0 0 24 24" class="w-4 h-4"><rect width="24" height="24" rx="2" fill="#00b67a"/><path d="M12 3.5l2.5 5.2 5.5.8-4 3.9 1 5.6-5-2.6-5 2.6 1-5.6-4-3.9 5.5-.8z" fill="white"/></svg>
          ))}
          <svg viewBox="0 0 24 24" class="w-4 h-4"><rect width="12" height="24" rx="2" fill="#00b67a"/><rect x="12" width="12" height="24" rx="2" fill="#dcdce6"/><path d="M12 3.5l2.5 5.2 5.5.8-4 3.9 1 5.6-5-2.6-5 2.6 1-5.6-4-3.9 5.5-.8z" fill="white"/></svg>
        </div>
        <a href={siteConfig.social.trustpilot} target="_blank" rel="noopener noreferrer" class="underline decoration-dotted text-neutral-300 hover:text-white transition-colors">{siteConfig.stats.trustpilotRating}/5 <span class="font-bold text-white">Trust</span><span class="font-bold text-[#00b67a]">pilot</span></a>
      </div>
      <span class="hidden sm:inline text-neutral-700">|</span>
      <a href="/courses" class="flex items-center gap-2 group">
        <span class="bg-accent-500 text-neutral-900 font-extrabold text-xs px-2.5 py-0.5 rounded-md uppercase tracking-wide animate-pulse">Spring Sale</span>
        <span class="text-neutral-300 group-hover:text-white transition-colors">0% finance on all courses</span>
      </a>
    </div>
  </div>

  <!-- ========== HERO ========== -->
  <section
    class="relative min-h-[60vh] md:min-h-[80vh] flex items-center overflow-hidden bg-neutral-900 bg-cover bg-center bg-no-repeat"
    style="background-image: url('/images/hero-banner.webp');"
    role="img"
    aria-label="Adult learner studying accredited online course on laptop at home"
  >
    <!-- Gradient overlay for text readability -->
    <div class="absolute inset-0 bg-gradient-to-r from-neutral-900/85 via-neutral-900/70 to-neutral-900/40"></div>

    <GradientMesh variant="hero" />

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 lg:py-32 w-full">
      <div class="max-w-2xl space-y-6">
        <div class="inline-flex items-center gap-2 bg-white/10 backdrop-blur-sm border border-white/20 text-white text-sm font-semibold px-4 py-1.5 rounded-full">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>
          Ofqual Regulated Qualifications
        </div>

        <h1 class="hero-heading font-display font-bold text-4xl sm:text-5xl xl:text-6xl leading-[1.08] tracking-tight text-white">
          Train Toward a <span class="text-primary-400">Career</span> You'll Love
        </h1>

        <p class="hero-subheading text-base md:text-lg text-neutral-200 leading-relaxed max-w-lg">
          Nationally recognised online courses in healthcare, accounting, security and more. <strong class="text-white">Expert tutor support</strong>, flexible study, and <strong class="text-white">0% finance</strong> available.
        </p>

        <div class="hero-ctas flex flex-col sm:flex-row gap-3">
          <a href="/courses" class="bg-gradient-to-r from-primary-500 to-primary-600 text-white px-7 py-3.5 rounded-xl font-bold text-base shadow-brand hover:shadow-brand-lg hover:-translate-y-0.5 active:translate-y-0 transition-all duration-300 text-center">
            Explore Courses
          </a>
          <a href="tel:01216909563" class="border-2 border-white/30 text-white px-7 py-3.5 rounded-xl font-bold text-base hover:border-white/60 hover:bg-white/10 transition-all duration-300 text-center flex items-center justify-center gap-2">
            <svg class="w-5 h-5 text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            0121 690 9563
          </a>
        </div>

        <div class="hero-trust flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-neutral-300 pt-2">
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-primary-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
            <span class="font-medium">{siteConfig.stats.years}+ Years</span>
          </div>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-primary-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
            <span class="font-medium">{siteConfig.stats.students.toLocaleString()}+ Students</span>
          </div>
          <div class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-primary-400" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
            <span class="font-medium">{siteConfig.stats.passRate}% Pass Rate</span>
          </div>
          <div class="flex items-center gap-1.5">
            <div class="flex items-center gap-0.5">
              {[1,2,3,4].map(() => (
                <svg viewBox="0 0 24 24" class="w-3.5 h-3.5"><rect width="24" height="24" rx="2" fill="#00b67a"/><path d="M12 3.5l2.5 5.2 5.5.8-4 3.9 1 5.6-5-2.6-5 2.6 1-5.6-4-3.9 5.5-.8z" fill="white"/></svg>
              ))}
              <svg viewBox="0 0 24 24" class="w-3.5 h-3.5"><rect width="12" height="24" rx="2" fill="#00b67a"/><rect x="12" width="12" height="24" rx="2" fill="#dcdce6"/><path d="M12 3.5l2.5 5.2 5.5.8-4 3.9 1 5.6-5-2.6-5 2.6 1-5.6-4-3.9 5.5-.8z" fill="white"/></svg>
            </div>
            <span class="font-medium">{siteConfig.stats.trustpilotRating}/5 <span class="font-bold text-white">Trust</span><span class="font-bold text-[#00b67a]">pilot</span></span>
          </div>
        </div>

        <!-- 0% Finance badge -->
        <div class="flex items-center gap-3 pt-2">
          <span class="bg-accent-500 text-neutral-900 font-extrabold text-sm px-3 py-1 rounded-lg">0% APR</span>
          <span class="text-white font-semibold">Interest-free finance on all courses</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== EMPLOYER LOGOS ========== -->
  <section class="py-5 bg-neutral-50 border-y border-neutral-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-center text-[10px] md:text-[11px] text-neutral-400 uppercase tracking-[0.2em] font-semibold mb-3">Our students & graduates work at</p>
      <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-3 md:gap-x-12">
        <div>
          <img src="/images/logos/nhs.svg" alt="NHS" class="h-10 md:h-14 w-auto" loading="lazy" />
        </div>
        <div>
          <img src="/images/logos/barclays.svg" alt="Barclays" class="h-9 md:h-12 w-auto" loading="lazy" />
        </div>
        <div>
          <img src="/images/logos/amazon.svg" alt="Amazon" class="h-8 md:h-10 w-auto" loading="lazy" />
        </div>
        <div>
          <img src="/images/logos/vodafone.svg" alt="Vodafone" class="h-9 md:h-12 w-auto" loading="lazy" />
        </div>
        <div>
          <img src="/images/logos/tesco.svg" alt="Tesco" class="h-9 md:h-12 w-auto" loading="lazy" />
        </div>
        <div>
          <img src="/images/logos/careuk.png" alt="Care UK" class="h-9 md:h-12 w-auto" loading="lazy" />
        </div>
        <div>
          <img src="/images/logos/govuk.svg" alt="Local Government" class="h-9 md:h-12 w-auto" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- ========== USP STRIP ========== -->
  <section class="bg-primary-600 py-5">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-white/20">
        <div class="flex items-center justify-center gap-3 py-3 sm:py-0 sm:px-4">
          <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
          </div>
          <div>
            <p class="text-white font-bold text-sm">Expert Tutors</p>
            <p class="text-white/70 text-xs">1-to-1 dedicated support</p>
          </div>
        </div>
        <div class="flex items-center justify-center gap-3 py-3 sm:py-0 sm:px-4">
          <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <div>
            <p class="text-white font-bold text-sm">Self-Paced, 100% Online</p>
            <p class="text-white/70 text-xs">Study around your life</p>
          </div>
        </div>
        <div class="flex items-center justify-center gap-3 py-3 sm:py-0 sm:px-4">
          <div class="w-10 h-10 rounded-full bg-white/20 flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <div>
            <p class="text-white font-bold text-sm">0% Interest Finance</p>
            <p class="text-white/70 text-xs">No credit check required</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== COURSE CATEGORIES ========== -->
  <section class="py-10 lg:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 lg:mb-10">
        <h2 class="font-display font-bold text-3xl md:text-4xl text-neutral-900 mb-3">
          Explore Our Online <span class="text-primary-500">Courses</span>
        </h2>
        <p class="text-neutral-600 max-w-xl mx-auto">
          Accredited by industry-leading awarding bodies. Nationally recognised qualifications that boost your skills and advance your career.
        </p>
      </div>

      <div class="services-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5">
        {siteConfig.services.map((service) => {
          const images = serviceImages[service.slug];
          const monthlyFrom = coursePricing[service.slug] || '£25';
          return (
            <a
              href={`/courses/${service.slug}`}
              class="service-card group relative bg-white rounded-xl overflow-hidden border border-neutral-200 hover:border-primary-300 hover:shadow-lg transition-all duration-300"
            >
              {/* Image */}
              <div class="relative h-44 overflow-hidden">
                <img
                  src={images?.thumbnail || '/images/hero-banner.webp'}
                  alt={images?.thumbnailAlt || service.name}
                  width="600"
                  height="400"
                  class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
                {/* Price badge */}
                <div class="absolute top-3 right-3 bg-white/95 backdrop-blur-sm text-neutral-900 font-bold text-sm px-3 py-1.5 rounded-lg shadow-md">
                  From {monthlyFrom}<span class="text-neutral-500 font-normal text-xs">/mo</span>
                </div>
              </div>
              {/* Content */}
              <div class="p-5">
                <h3 class="font-display font-bold text-neutral-900 mb-2 group-hover:text-primary-600 transition-colors text-lg">
                  {service.name}
                </h3>
                <p class="text-neutral-600 text-sm leading-relaxed mb-3 line-clamp-2">
                  {service.shortDescription}
                </p>
                <div class="flex items-center justify-between">
                  <span class="inline-flex items-center gap-1.5 text-primary-500 font-semibold text-sm group-hover:text-primary-600 transition-colors">
                    View Courses
                    <svg class="w-4 h-4 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                  </span>
                  <span class="text-xs text-neutral-400 font-medium">0% Finance</span>
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <div class="text-center mt-8">
        <a href="/courses" class="inline-flex items-center gap-2 bg-neutral-900 text-white font-bold px-8 py-3.5 rounded-xl hover:bg-neutral-800 transition-colors">
          View All 30+ Courses
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ========== 0% FINANCE BANNER ========== -->
  <section class="bg-gradient-to-r from-primary-700 via-primary-600 to-primary-500 py-10 lg:py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="flex items-center gap-4 text-center md:text-left">
          <div class="hidden md:flex w-16 h-16 rounded-2xl bg-white/20 items-center justify-center flex-shrink-0">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <div>
            <div class="flex items-center gap-3 mb-1 justify-center md:justify-start">
              <span class="bg-accent-500 text-neutral-900 font-extrabold text-sm px-3 py-1 rounded-lg">0% APR</span>
              <h3 class="font-display font-bold text-2xl md:text-3xl text-white">Interest-Free Finance</h3>
            </div>
            <p class="text-white/80 max-w-lg">
              Spread the cost with affordable monthly payments. No credit check. No hidden fees. Start learning today.
            </p>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row items-center gap-3">
          <a href="/courses" class="bg-white text-primary-700 font-bold px-7 py-3 rounded-xl hover:bg-neutral-50 transition-colors shadow-lg whitespace-nowrap">
            Browse Courses
          </a>
          <a href="tel:01216909563" class="border-2 border-white/30 text-white font-bold px-7 py-3 rounded-xl hover:bg-white/10 transition-colors whitespace-nowrap">
            Call {siteConfig.phone}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== STATS ========== -->
  <section class="stats-bar bg-neutral-900 py-14 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-5 gap-6 md:gap-8">
        <div class="text-center">
          <div class="stat-number font-display font-bold text-4xl md:text-6xl text-white leading-none" data-target="25">0</div>
          <p class="text-white/60 text-xs md:text-sm font-medium mt-1.5">Years in Education</p>
        </div>
        <div class="text-center">
          <div class="flex items-baseline justify-center">
            <div class="stat-number font-display font-bold text-4xl md:text-6xl text-white leading-none" data-target="50000">0</div>
            <span class="text-white/40 text-lg md:text-xl font-bold ml-0.5">+</span>
          </div>
          <p class="text-white/60 text-xs md:text-sm font-medium mt-1.5">Learners Trained</p>
        </div>
        <div class="text-center">
          <div class="flex items-baseline justify-center">
            <div class="stat-number font-display font-bold text-4xl md:text-6xl text-white leading-none" data-target="93">0</div>
            <span class="text-white/40 text-lg md:text-xl font-bold ml-0.5">%</span>
          </div>
          <p class="text-white/60 text-xs md:text-sm font-medium mt-1.5">Pass Rate</p>
        </div>
        <div class="text-center">
          <div class="flex items-baseline justify-center">
            <div class="font-display font-bold text-4xl md:text-6xl text-white leading-none">4.8</div>
