<script>
  document.addEventListener('astro:page-load', () => {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    // @ts-ignore
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
    // @ts-ignore
    gsap.registerPlugin(ScrollTrigger);

    // Service card stagger
    const serviceCards = document.querySelectorAll('.services-grid .service-card');
    if (serviceCards.length > 0) {
      // @ts-ignore
      gsap.set('.services-grid .service-card', { y: 30, opacity: 0 });
      // @ts-ignore
      gsap.to('.services-grid .service-card',
        { // @ts-ignore
          scrollTrigger: { trigger: '.services-grid', start: 'top 85%' },
          y: 0, opacity: 1,
          duration: 0.4,
          stagger: 0.08,
          ease: 'power2.out',
        }
      );
      setTimeout(() => {
        serviceCards.forEach((card) => {
          if (getComputedStyle(card).opacity === '0') {
            (card as HTMLElement).style.opacity = '1';
            (card as HTMLElement).style.transform = 'none';
          }
        });
      }, 3000);
    }

    // Stats count up
    // @ts-ignore
    ScrollTrigger.create({
      trigger: '.stats-bar',
      start: 'top 80%',
      once: true,
      onEnter: () => {
        document.querySelectorAll('.stat-number').forEach((el) => {
          const target = parseInt((el as HTMLElement).dataset.target || '0');
          // @ts-ignore
          gsap.to(el, {
            innerHTML: target,
            duration: 2,
            snap: { innerHTML: 1 },
            ease: 'power2.out',
          });
        });
      },
    });

    // Hero animations
    const heroElements = ['.hero-heading', '.hero-subheading', '.hero-ctas', '.hero-trust'];

    // Reset all hero elements to visible first (fix for back-navigation)
    heroElements.forEach((sel) => {
      const el = document.querySelector(sel) as HTMLElement;
      if (el) {
        el.style.opacity = '1';
        el.style.transform = 'none';
      }
    });

    const heroHeading = document.querySelector('.hero-heading');
    if (heroHeading) {
      // @ts-ignore
      const tl = gsap.timeline();
      // @ts-ignore
      tl.from('.hero-heading', { y: 30, opacity: 0, duration: 0.6, ease: 'power2.out' })
      // @ts-ignore
        .from('.hero-subheading', { y: 20, opacity: 0, duration: 0.5, ease: 'power2.out' }, '-=0.3')
      // @ts-ignore
        .from('.hero-ctas', { y: 15, opacity: 0, duration: 0.4 }, '-=0.2')
      // @ts-ignore
        .from('.hero-trust', { y: 15, opacity: 0, duration: 0.4 }, '-=0.1');
    }

    // Fallback: ensure hero is visible even if GSAP fails
    setTimeout(() => {
      heroElements.forEach((sel) => {
        const el = document.querySelector(sel) as HTMLElement;
        if (el && getComputedStyle(el).opacity === '0') {
          el.style.opacity = '1';
          el.style.transform = 'none';
        }
      });
    }, 2000);
  });
</script>
