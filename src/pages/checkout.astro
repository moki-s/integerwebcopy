---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Cart', href: '/cart' },
  { label: 'Checkout', href: '/checkout' },
];

const stripePublishableKey = import.meta.env.PUBLIC_STRIPE_PUBLISHABLE_KEY || '';
---

<BaseLayout
  title="Secure Checkout | Integer Training"
  description="Complete your course enrolment with our secure Stripe-powered checkout."
>
  <Breadcrumb items={breadcrumbs} />

  <section class="py-12 lg:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Step Indicator -->
      <div class="mb-10">
        <div class="flex items-center justify-center gap-0">
          <!-- Step 1: Basket -->
          <div class="flex items-center">
            <div class="flex flex-col items-center">
              <div class="w-9 h-9 rounded-full bg-primary-500 text-white flex items-center justify-center text-sm font-bold shadow-sm">1</div>
              <span class="text-xs font-semibold text-primary-600 mt-1.5 whitespace-nowrap">Basket</span>
            </div>
          </div>
          <div class="w-12 sm:w-20 h-0.5 bg-primary-500 mt-[-0.75rem]"></div>
          <!-- Step 2: Details -->
          <div class="flex items-center">
            <div class="flex flex-col items-center">
              <div class="w-9 h-9 rounded-full bg-primary-500 text-white flex items-center justify-center text-sm font-bold shadow-sm">2</div>
              <span class="text-xs font-semibold text-primary-600 mt-1.5 whitespace-nowrap">Details</span>
            </div>
          </div>
          <div class="w-12 sm:w-20 h-0.5 bg-primary-500 mt-[-0.75rem]"></div>
          <!-- Step 3: Payment (Active) -->
          <div class="flex items-center">
            <div class="flex flex-col items-center">
              <div class="w-9 h-9 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 text-white flex items-center justify-center text-sm font-bold shadow-brand ring-4 ring-primary-100">3</div>
              <span class="text-xs font-bold text-primary-700 mt-1.5 whitespace-nowrap">Payment</span>
            </div>
          </div>
          <div class="w-12 sm:w-20 h-0.5 bg-neutral-200 mt-[-0.75rem]"></div>
          <!-- Step 4: Complete -->
          <div class="flex items-center">
            <div class="flex flex-col items-center">
              <div class="w-9 h-9 rounded-full bg-neutral-200 text-neutral-400 flex items-center justify-center text-sm font-bold">4</div>
              <span class="text-xs font-medium text-neutral-400 mt-1.5 whitespace-nowrap">Complete</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Payment Mode Badge -->
      <div class="flex items-center justify-center gap-3 mb-8">
        <span id="mode-badge-full" class="hidden inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-primary-50 text-primary-700 text-sm font-semibold border border-primary-200">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2z"/></svg>
          One-Time Payment
        </span>
        <span id="mode-badge-monthly" class="hidden inline-flex items-center gap-1.5 px-4 py-1.5 rounded-full bg-green-50 text-green-700 text-sm font-semibold border border-green-200">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          Monthly Plan
        </span>
        <a href="/cart" class="text-sm text-primary-500 font-semibold hover:text-primary-600 transition-colors underline underline-offset-2">Change</a>
      </div>

      <h1 class="font-display font-bold text-3xl md:text-4xl text-neutral-900 mb-8 text-center">Secure Checkout</h1>

      <div id="checkout-error-banner" class="hidden bg-red-50 text-red-700 px-4 py-3 rounded-xl mb-6 text-center font-medium text-sm"></div>

      <div class="grid grid-cols-1 lg:grid-cols-5 gap-8">
        <!-- Form -->
        <div class="lg:col-span-3">
          <form id="checkout-form" data-stripe-key={stripePublishableKey}>
            <!-- Customer Details -->
            <div class="bg-white rounded-2xl border border-neutral-100 shadow-brand-sm p-6 mb-6">
              <h3 class="font-display font-bold text-lg text-neutral-900 mb-4 flex items-center gap-3">
                <span class="w-7 h-7 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 text-white flex items-center justify-center text-sm font-bold">1</span>
                Customer Details
              </h3>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-4">
                <div>
                  <label for="first_name" class="block text-sm font-medium text-neutral-700 mb-1">First Name <span class="text-red-500">*</span></label>
                  <input type="text" id="first_name" name="first_name" required class="w-full px-4 py-3 rounded-xl border border-neutral-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-base" />
                </div>
                <div>
                  <label for="last_name" class="block text-sm font-medium text-neutral-700 mb-1">Last Name <span class="text-red-500">*</span></label>
                  <input type="text" id="last_name" name="last_name" required class="w-full px-4 py-3 rounded-xl border border-neutral-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-base" />
                </div>
              </div>
              <div class="mb-4">
                <label for="checkout_email" class="block text-sm font-medium text-neutral-700 mb-1">Email Address <span class="text-red-500">*</span></label>
                <input type="email" id="checkout_email" name="email" required class="w-full px-4 py-3 rounded-xl border border-neutral-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-base" />
              </div>
              <div>
                <label for="checkout_phone" class="block text-sm font-medium text-neutral-700 mb-1">Phone Number <span class="text-red-500">*</span></label>
                <input type="tel" id="checkout_phone" name="phone" required class="w-full px-4 py-3 rounded-xl border border-neutral-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-base" />
              </div>
            </div>

            <!-- Monthly Plan Setup (visible only when Pay Monthly mode) -->
            <div id="monthly-plan-section" class="hidden bg-white rounded-2xl border border-neutral-100 shadow-brand-sm p-6 mb-6">
              <h3 class="font-display font-bold text-lg text-neutral-900 mb-4 flex items-center gap-3">
                <span class="w-7 h-7 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 text-white flex items-center justify-center text-sm font-bold">2</span>
                Choose Monthly Payment Method
              </h3>

              <!-- Method radio -->
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                <label id="dd-card-option" class="dd-method-card flex flex-col p-4 border-2 border-primary-500 bg-primary-50 rounded-xl cursor-pointer transition-all">
                  <input type="radio" name="dd_method" value="card" checked class="sr-only" />
                  <div class="flex items-center gap-2 mb-1">
                    <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
                    <span class="font-bold text-sm">Pay by Card</span>
                  </div>
                  <span class="text-xs text-neutral-600">£20 registration today + 12 monthly card payments.</span>
                </label>
                <label id="dd-debit-option" class="dd-method-card flex flex-col p-4 border-2 border-neutral-200 rounded-xl cursor-pointer transition-all">
                  <input type="radio" name="dd_method" value="bacs_debit" class="sr-only" />
                  <div class="flex items-center gap-2 mb-1">
                    <svg class="w-5 h-5 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
                    <span class="font-bold text-sm">Pay by Direct Debit</span>
                  </div>
                  <span class="text-xs text-neutral-600">£20 registration + 12 Direct Debits. Allow 3–5 working days to clear.</span>
                </label>
              </div>

              <!-- First installment date (always visible when monthly) -->
              <div id="first-payment-date-section" class="mt-4 pt-4 border-t border-neutral-100">
                <label for="first_payment_date" class="block text-sm font-medium text-neutral-700 mb-1">
                  First installment date <span class="text-red-500">*</span>
                </label>
                <input type="date" id="first_payment_date" class="w-full px-4 py-3 rounded-xl border border-neutral-200 focus:border-primary-500 focus:ring-2 focus:ring-primary-500/20 outline-none transition-all text-base" />
                <p id="first-payment-help" class="text-xs text-neutral-500 mt-2">
                  <svg class="w-3.5 h-3.5 inline -mt-0.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  Today we charge the £20 registration fee. Your 12 monthly installments of <span id="installment-amount">--</span> start on this date.
                </p>
              </div>
            </div>

            <!-- Payment Details (card element) — hidden when DD selected -->
            <div id="card-section" class="bg-white rounded-2xl border border-neutral-100 shadow-brand-sm p-6">
              <h3 class="font-display font-bold text-lg text-neutral-900 mb-4 flex items-center gap-3">
                <span id="payment-step-num" class="w-7 h-7 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 text-white flex items-center justify-center text-sm font-bold">2</span>
                <span id="payment-step-label">Payment Details</span>
              </h3>

              <div id="stripe-card-element" class="bg-white border border-neutral-200 px-4 py-3 rounded-xl"></div>
              <div id="stripe-card-errors" class="text-red-500 text-sm mt-2 min-h-[1.2em]"></div>

              <div class="mt-6 space-y-3">
                <label class="flex items-center gap-3 cursor-pointer text-sm text-neutral-700">
                  <input type="checkbox" id="terms-agree" class="w-5 h-5 rounded border-neutral-300 text-primary-500 focus:ring-primary-500" />
                  I agree to the <a href="/terms" target="_blank" class="text-primary-500 underline font-semibold">Terms and Conditions</a>
                </label>
                <label class="flex items-center gap-3 cursor-pointer text-sm text-neutral-700">
                  <input type="checkbox" id="privacy-agree" class="w-5 h-5 rounded border-neutral-300 text-primary-500 focus:ring-primary-500" />
                  I agree to the <a href="/privacy-policy" target="_blank" class="text-primary-500 underline font-semibold">Privacy Policy</a>
                </label>
                <div id="terms-error" class="hidden text-red-500 text-xs">You must agree to both policies to proceed.</div>
              </div>

              <button
                type="submit"
                id="submit-btn"
                class="w-full mt-6 bg-gradient-to-r from-primary-500 to-primary-600 text-white px-6 py-4 rounded-xl font-bold text-lg shadow-brand hover:shadow-brand-lg hover:-translate-y-0.5 active:translate-y-0 transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:translate-y-0"
              >
                <span id="btn-text">Pay Now</span>
                <span id="btn-spinner" class="hidden">Processing...</span>
              </button>
            </div>

            <!-- DD redirect notice — visible only when DD selected -->
            <div id="dd-redirect-section" class="hidden bg-white rounded-2xl border border-neutral-100 shadow-brand-sm p-6">
              <h3 class="font-display font-bold text-lg text-neutral-900 mb-4 flex items-center gap-3">
                <span class="w-7 h-7 rounded-full bg-gradient-to-br from-primary-500 to-primary-600 text-white flex items-center justify-center text-sm font-bold">3</span>
                Bank Details (via Stripe)
              </h3>
              <div class="bg-amber-50 border border-amber-100 rounded-xl px-4 py-3 mb-4">
                <p class="text-sm text-amber-900 leading-relaxed">
                  <svg class="w-4 h-4 inline -mt-0.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  After clicking <strong>Continue to bank details</strong>, you'll be redirected to Stripe to securely enter your sort code and account number. The £20 registration fee and your 12 monthly Direct Debits will be collected from this account. <strong>Allow 3–5 working days</strong> for the first Direct Debit to clear.
                </p>
              </div>
              <div class="space-y-3 mb-4">
                <label class="flex items-center gap-3 cursor-pointer text-sm text-neutral-700">
                  <input type="checkbox" id="terms-agree-dd" class="w-5 h-5 rounded border-neutral-300 text-primary-500 focus:ring-primary-500" />
                  I agree to the <a href="/terms" target="_blank" class="text-primary-500 underline font-semibold">Terms and Conditions</a>
                </label>
                <label class="flex items-center gap-3 cursor-pointer text-sm text-neutral-700">
                  <input type="checkbox" id="privacy-agree-dd" class="w-5 h-5 rounded border-neutral-300 text-primary-500 focus:ring-primary-500" />
                  I agree to the <a href="/privacy-policy" target="_blank" class="text-primary-500 underline font-semibold">Privacy Policy</a>
                </label>
                <div id="terms-error-dd" class="hidden text-red-500 text-xs">You must agree to both policies to proceed.</div>
              </div>
              <button
                type="button"
                id="submit-btn-dd"
                class="w-full bg-gradient-to-r from-primary-500 to-primary-600 text-white px-6 py-4 rounded-xl font-bold text-lg shadow-brand hover:shadow-brand-lg hover:-translate-y-0.5 active:translate-y-0 transition-all duration-300 disabled:opacity-50 disabled:cursor-not-allowed"
              >
                <span id="btn-text-dd">Continue to bank details</span>
                <span id="btn-spinner-dd" class="hidden">Redirecting...</span>
              </button>

              <!-- Trust Elements -->
              <div class="mt-4 flex items-center justify-center gap-5 text-neutral-400 text-xs">
                <span class="flex items-center gap-1.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
                  256-bit SSL
                </span>
                <span class="flex items-center gap-1.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                  Stripe Secured
                </span>
                <span class="flex items-center gap-1.5">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                  4.8/5 Trustpilot
                </span>
              </div>
            </div>
          </form>
        </div>

        <!-- Order Summary -->
        <div class="lg:col-span-2">
          <div class="bg-neutral-50 rounded-2xl p-6 border border-neutral-100 sticky top-28">
            <h3 class="font-display font-bold text-lg text-neutral-900 mb-4">Order Summary</h3>
            <div id="checkout-items" class="space-y-3 mb-4"></div>

            <!-- Full Payment Summary -->
            <div id="summary-full" class="hidden border-t border-neutral-200 pt-4 space-y-2">
              <div class="flex justify-between text-sm text-neutral-600">
                <span>Subtotal (ex. VAT)</span>
                <span id="checkout-subtotal">--</span>
              </div>
              <div class="flex justify-between text-sm text-neutral-500">
                <span>VAT (20%)</span>
                <span id="checkout-vat">--</span>
              </div>
              <div class="flex justify-between font-bold text-lg text-neutral-900 border-t border-neutral-200 pt-3 mt-3">
                <span>Total to Pay</span>
                <span id="checkout-total">--</span>
              </div>
            </div>

            <!-- Monthly Payment Summary (£20 reg + 12 installments) -->
            <div id="summary-monthly" class="hidden border-t border-neutral-200 pt-4 space-y-2">
              <div class="flex justify-between text-sm text-neutral-700">
                <span>Registration fee (today)</span>
                <span id="checkout-monthly-subtotal">--</span>
              </div>
              <div class="flex justify-between text-sm text-neutral-400">
                <span class="text-xs">VAT status</span>
                <span id="checkout-monthly-vat" class="text-xs">--</span>
              </div>
              <div class="flex justify-between text-sm font-semibold text-neutral-900">
                <span>Monthly installment</span>
                <span id="checkout-monthly-amount">--</span>
              </div>
              <div class="flex justify-between text-sm text-neutral-600">
                <span>Number of installments</span>
                <span class="font-medium">12</span>
              </div>
              <div class="flex justify-between text-sm font-bold text-neutral-900 border-t border-neutral-200 pt-3 mt-3">
                <span>Total (13 payments)</span>
                <span id="checkout-monthly-total-12">--</span>
              </div>
              <div class="bg-green-50 border border-green-100 rounded-lg px-3 py-2 mt-3">
                <p id="monthly-summary-note" class="text-xs text-green-700 leading-relaxed">
                  <svg class="w-3.5 h-3.5 inline -mt-0.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  First payment today, then monthly card auto-billing for 12 months.
                </p>
              </div>
            </div>

            <a href="/cart" class="block text-center text-primary-500 font-semibold text-sm mt-4 hover:text-primary-600 transition-colors">
              &larr; Back to Cart
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script is:inline src="https://js.stripe.com/v3/"></script>

<script>
  import { getCart, getCartTotal, getCartMonthlyTotal, getCartCourseIds, getPaymentMode, clearCart } from '../lib/cart';
  import type { PaymentMode } from '../lib/cart';

  document.addEventListener('astro:page-load', () => {
    const items = getCart();

    // Redirect to cart if empty
    if (items.length === 0) {
      window.location.href = '/cart';
      return;
    }

    // Determine payment mode
    const paymentMode: PaymentMode = getPaymentMode();
    const isMonthly = paymentMode === 'monthly';

    // Show correct payment mode badge
    const badgeFull = document.getElementById('mode-badge-full')!;
    const badgeMonthly = document.getElementById('mode-badge-monthly')!;
    if (isMonthly) {
      badgeMonthly.classList.remove('hidden');
      badgeMonthly.classList.add('inline-flex');
    } else {
      badgeFull.classList.remove('hidden');
      badgeFull.classList.add('inline-flex');
    }

    // Show correct summary section
    const summaryFull = document.getElementById('summary-full')!;
    const summaryMonthly = document.getElementById('summary-monthly')!;

    if (isMonthly) {
      summaryMonthly.classList.remove('hidden');
      summaryFull.classList.add('hidden');
    } else {
      summaryFull.classList.remove('hidden');
      summaryMonthly.classList.add('hidden');
    }

    // Calculate totals — `total` is sum of course.price (inc VAT, same value as pay-in-full)
    const total = getCartTotal();
    const subtotalExVat = total / 1.2;
    const vat = total - subtotalExVat;
    // Monthly = same total, split as £20 reg + 12 installments.
    // Round installment to match server-side pricing.calculatePlan (M6).
    const REG_FEE = 20;
    const monthlyInstallment = Math.round((total - REG_FEE) / 12 * 100) / 100;
    const monthlyTotal = monthlyInstallment; // backwards-compat alias for places that reference it

    // Populate full payment summary
    document.getElementById('checkout-subtotal')!.textContent = `\u00A3${subtotalExVat.toFixed(2)}`;
    document.getElementById('checkout-vat')!.textContent = `\u00A3${vat.toFixed(2)}`;
    document.getElementById('checkout-total')!.textContent = `\u00A3${total.toFixed(2)}`;

    // Populate monthly payment summary
    document.getElementById('checkout-monthly-subtotal')!.textContent = `\u00A320.00`;
    document.getElementById('checkout-monthly-vat')!.textContent = `inc VAT`;
    document.getElementById('checkout-monthly-amount')!.textContent = `\u00A3${monthlyInstallment.toFixed(2)}/mo`;
    document.getElementById('checkout-monthly-total-12')!.textContent = `\u00A3${(20 + monthlyInstallment * 12).toFixed(2)}`;

    // Set initial button text (may be updated by DD radio handler below)
    const btnTextEl = document.getElementById('btn-text')!;
    if (isMonthly) {
      btnTextEl.textContent = `Start Monthly Plan - \u00A3${monthlyTotal.toFixed(2)}/mo`;
    } else {
      btnTextEl.textContent = `Pay \u00A3${total.toFixed(2)}`;
    }

    // ====================================================================
    // Monthly plan: registration fee + 12 installments, card or DD
    // ====================================================================
    let ddMethod: 'card' | 'bacs_debit' = 'card';
    const monthlyPlanSection = document.getElementById('monthly-plan-section')!;
    const cardSection = document.getElementById('card-section')!;
    const ddRedirectSection = document.getElementById('dd-redirect-section')!;
    const firstPaymentDateInput = document.getElementById('first_payment_date') as HTMLInputElement;
    const installmentAmountSpan = document.getElementById('installment-amount')!;
    const monthlyNote = document.getElementById('monthly-summary-note')!;
    const cardOption = document.getElementById('dd-card-option')!;
    const debitOption = document.getElementById('dd-debit-option')!;

    function pad(n: number) { return n.toString().padStart(2, '0'); }
    function isoDate(d: Date) { return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`; }

    // Installment for display (same as monthlyInstallment computed above).
    const installmentDisplay = monthlyInstallment;

    if (isMonthly) {
      monthlyPlanSection.classList.remove('hidden');
      installmentAmountSpan.textContent = `\u00A3${installmentDisplay.toFixed(2)}`;

      // Date constraints \u2014 mirror server-side pricing.validateFirstPaymentDate exactly:
      //   card: today+5 calendar days .. today+30
      //   bacs: today+5 WORKING days .. today+30
      // Recompute min when the radio changes so DD customers never pick a date
      // the server will reject. UTC midnight throughout to match server math. (H9, C2)
      const today = new Date();
      today.setUTCHours(0,0,0,0);
      const max = new Date(today); max.setUTCDate(today.getUTCDate() + 30);
      const maxIso = isoDate(max);

      function addWorkingDays(from: Date, n: number): Date {
        const d = new Date(from);
        let added = 0;
        while (added < n) {
          d.setUTCDate(d.getUTCDate() + 1);
          const dow = d.getUTCDay();
          if (dow !== 0 && dow !== 6) added++;
        }
        return d;
      }

      function computeMin(method: 'card' | 'bacs_debit'): Date {
        if (method === 'bacs_debit') return addWorkingDays(today, 5);
        const m = new Date(today); m.setUTCDate(today.getUTCDate() + 5);
        return m;
      }

      function applyDateConstraints(method: 'card' | 'bacs_debit') {
        const min = computeMin(method);
        const minIso = isoDate(min);
        firstPaymentDateInput.min = minIso;
        firstPaymentDateInput.max = maxIso;
        // If current value is now out of range, snap to min
        const cur = firstPaymentDateInput.value;
        if (!cur || cur < minIso || cur > maxIso) {
          firstPaymentDateInput.value = minIso;
        }
      }

      applyDateConstraints('card'); // initial state (card is default-selected)

      // Show valid range in the help text
      const fmt = (d: Date) => d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short' });
      const helpEl = document.getElementById('first-payment-help');
      if (helpEl) {
        helpEl.innerHTML = `<svg class="w-3.5 h-3.5 inline -mt-0.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg> Pick any date between <strong>${fmt(min)}</strong> and <strong>${fmt(max)}</strong>. Today we charge the \u00A320 registration fee. Your 12 monthly installments of <span id="installment-amount">\u00A3${installmentDisplay.toFixed(2)}</span> start on this date.`;
      }

      // Snap any out-of-range typed/picked values back into range
      firstPaymentDateInput.addEventListener('input', () => {
        const v = firstPaymentDateInput.value;
        if (!v) return;
        if (v < minIso) firstPaymentDateInput.value = minIso;
        else if (v > maxIso) firstPaymentDateInput.value = maxIso;
      });

      function selectMethod(method: 'card' | 'bacs_debit') {
        ddMethod = method;
        applyDateConstraints(method); // DD uses working days; card uses calendar
        if (method === 'card') {
          cardOption.classList.add('border-primary-500', 'bg-primary-50');
          cardOption.classList.remove('border-neutral-200');
          debitOption.classList.remove('border-primary-500', 'bg-primary-50');
          debitOption.classList.add('border-neutral-200');
          cardSection.classList.remove('hidden');
          ddRedirectSection.classList.add('hidden');
          btnTextEl.textContent = `Pay \u00A320 registration & start plan`;
          monthlyNote.innerHTML = `<svg class="w-3.5 h-3.5 inline -mt-0.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg> \u00A320 registration today + 12 monthly card payments of \u00A3${installmentDisplay.toFixed(2)}.`;
        } else {
          debitOption.classList.add('border-primary-500', 'bg-primary-50');
          debitOption.classList.remove('border-neutral-200');
          cardOption.classList.remove('border-primary-500', 'bg-primary-50');
          cardOption.classList.add('border-neutral-200');
          cardSection.classList.add('hidden');
          ddRedirectSection.classList.remove('hidden');
          monthlyNote.innerHTML = `<svg class="w-3.5 h-3.5 inline -mt-0.5 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg> \u00A320 registration + 12 Direct Debits of \u00A3${installmentDisplay.toFixed(2)}. Earliest DD date is 5 working days from today.`;
        }
      }

      cardOption.addEventListener('click', () => selectMethod('card'));
      debitOption.addEventListener('click', () => selectMethod('bacs_debit'));
    }

    // Render cart items - show per-item price based on mode
    document.getElementById('checkout-items')!.innerHTML = items
      .map(
        ({ course }) => `
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-lg overflow-hidden flex-shrink-0 bg-white border border-neutral-100">
          <img src="${course.image}" alt="${course.title}" class="w-full h-full object-cover" loading="lazy" />
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold text-neutral-900 truncate">${course.title}</p>
          <p class="text-xs text-neutral-500">Qty: 1</p>
        </div>
        <p class="text-sm font-semibold text-neutral-900">\u00A3${course.price.toFixed(2)}</p>
      </div>`,
      )
      .join('');

    // Stripe setup
    const form = document.getElementById('checkout-form') as HTMLFormElement;
    const stripeKey = form?.dataset.stripeKey;
    if (!stripeKey || !window.Stripe) return;

    const stripe = window.Stripe(stripeKey);
    const elements = stripe.elements();
    const card = elements.create('card', {
      style: {
        base: {
          fontSize: '16px',
          color: '#1a1a1a',
          fontFamily: '"Inter", sans-serif',
          '::placeholder': { color: '#999' },
        },
        invalid: { color: '#e53e3e' },
      },
    });
    card.mount('#stripe-card-element');

    const errorEl = document.getElementById('stripe-card-errors')!;
    card.on('change', (event: any) => {
      errorEl.textContent = event.error ? event.error.message : '';
    });

    let isProcessing = false;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const btnText = document.getElementById('btn-text')!;
    const btnSpinner = document.getElementById('btn-spinner')!;

    function setLoading(loading: boolean) {
      isProcessing = loading;
      submitBtn.disabled = loading;
      btnText.classList.toggle('hidden', loading);
      btnSpinner.classList.toggle('hidden', !loading);
    }

    function storeOrderAndRedirect(orderNumber: string, firstName: string, lastName: string, email: string, orderTotal: number, extras: Record<string, unknown> = {}) {
      const orderData: Record<string, unknown> = {
        order_number: orderNumber,
        customer_name: `${firstName} ${lastName}`,
        customer_email: email,
        courses: items.map((i) => i.course.title),
        total: orderTotal,
        ...extras,
      };
      if (isMonthly && !orderData.payment_type) {
        orderData.payment_type = 'monthly';
        orderData.subscription_months = 12;
      }
      sessionStorage.setItem('last_order', JSON.stringify(orderData));
      clearCart();
      window.location.href = '/order-success';
    }

    // ====================================================================
    // DD button — separate from form submit. Posts to DD endpoint and redirects.
    // ====================================================================
    const submitBtnDd = document.getElementById('submit-btn-dd') as HTMLButtonElement | null;
    const btnTextDd = document.getElementById('btn-text-dd');
    const btnSpinnerDd = document.getElementById('btn-spinner-dd');

    if (submitBtnDd && btnTextDd && btnSpinnerDd) {
      submitBtnDd.addEventListener('click', async (e: Event) => {
        e.preventDefault();
        if (isProcessing) return;

        const firstName = (document.getElementById('first_name') as HTMLInputElement).value.trim();
        const lastName = (document.getElementById('last_name') as HTMLInputElement).value.trim();
        const email = (document.getElementById('checkout_email') as HTMLInputElement).value.trim();
        const phone = (document.getElementById('checkout_phone') as HTMLInputElement).value.trim();
        const firstPaymentDate = firstPaymentDateInput.value;

        if (!firstName || !lastName || !email || !phone) {
          alert('Please fill in your name, email and phone before continuing.');
          return;
        }
        if (!firstPaymentDate) {
          alert('Please pick your first installment date.');
          return;
        }

        const termsBox = document.getElementById('terms-agree-dd') as HTMLInputElement;
        const privacyBox = document.getElementById('privacy-agree-dd') as HTMLInputElement;
        const termsErr = document.getElementById('terms-error-dd')!;
        if (!termsBox.checked || !privacyBox.checked) {
          termsErr.classList.remove('hidden');
          return;
        }
        termsErr.classList.add('hidden');

        isProcessing = true;
        submitBtnDd.disabled = true;
        btnTextDd.classList.add('hidden');
        btnSpinnerDd.classList.remove('hidden');

        try {
          const response = await fetch('/api/checkout-direct-debit-session', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              first_name: firstName,
              last_name: lastName,
              email,
              phone,
              course_ids: getCartCourseIds(),
              first_payment_date: firstPaymentDate,
            }),
          });

          const data = await response.json();

          if (data.success && data.checkout_url) {
            // Stash details for /order-success but DON'T clear cart yet — if customer
            // cancels on Stripe and hits Back, they should see their cart intact. (H8)
            // The order-success page pops `pending_dd_order` only when session_id is
            // present in the URL (i.e. Stripe redirected back, not a Back-button hit).
            sessionStorage.setItem('pending_dd_order', JSON.stringify({
              order_number: data.order_number,
              customer_name: `${firstName} ${lastName}`,
              customer_email: email,
              courses: items.map((i) => i.course.title),
              total: 20 + installmentDisplay * 12,
              payment_type: 'monthly',
              payment_method: 'bacs_debit',
              registration_fee: 20,
              monthly_amount: installmentDisplay,
              subscription_months: 12,
              first_payment_date: data.first_payment_date,
              session_id: data.session_id,
            }));
            window.location.href = data.checkout_url;
            return;
          }

          alert(data.error || 'Could not set up Direct Debit. Please try again.');
        } catch {
          alert('An error occurred. Please try again or call us on 0121 690 9563 for assistance.');
        } finally {
          isProcessing = false;
          submitBtnDd.disabled = false;
          btnTextDd.classList.remove('hidden');
          btnSpinnerDd.classList.add('hidden');
        }
      });
    }

    form.addEventListener('submit', async (e: Event) => {
      e.preventDefault();
      if (isProcessing) return;

      const firstName = (document.getElementById('first_name') as HTMLInputElement).value.trim();
      const lastName = (document.getElementById('last_name') as HTMLInputElement).value.trim();
      const email = (document.getElementById('checkout_email') as HTMLInputElement).value.trim();
      const phone = (document.getElementById('checkout_phone') as HTMLInputElement).value.trim();

      if (!firstName || !lastName || !email || !phone) {
        errorEl.textContent = 'Please fill in all required fields.';
        return;
      }

      const termsBox = document.getElementById('terms-agree') as HTMLInputElement;
      const privacyBox = document.getElementById('privacy-agree') as HTMLInputElement;
      const termsErr = document.getElementById('terms-error')!;

      if (!termsBox.checked || !privacyBox.checked) {
        termsErr.classList.remove('hidden');
        return;
      }
      termsErr.classList.add('hidden');
      errorEl.textContent = '';
      setLoading(true);

      try {
        const result = await stripe.createPaymentMethod({
          type: 'card',
          card,
          billing_details: { name: `${firstName} ${lastName}`, email, phone },
        });

        if (result.error) {
          errorEl.textContent = result.error.message || 'Card error';
          setLoading(false);
          return;
        }

        if (isMonthly && !firstPaymentDateInput.value) {
          errorEl.textContent = 'Please pick your first installment date.';
          setLoading(false);
          return;
        }

        const payload: Record<string, unknown> = {
          payment_method_id: result.paymentMethod.id,
          first_name: firstName,
          last_name: lastName,
          email,
          phone,
          course_ids: getCartCourseIds(),
        };
        if (isMonthly) {
          payload.first_payment_date = firstPaymentDateInput.value;
        }

        // Endpoint routing:
        //   one-time card → /api/checkout
        //   monthly card → /api/checkout-subscription (DD has its own button below)
        const endpoint = isMonthly ? '/api/checkout-subscription' : '/api/checkout';

        const response = await fetch(endpoint, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });

        const data = await response.json();

        if (data.success) {
          const orderTotal = isMonthly ? (20 + installmentDisplay * 12) : total;
          const extras: Record<string, unknown> = {};
          if (isMonthly) {
            extras.registration_fee = 20;
            extras.monthly_amount = installmentDisplay;
            extras.first_payment_date = firstPaymentDateInput.value;
            extras.payment_method = 'card';
          }
          storeOrderAndRedirect(data.order_number, firstName, lastName, email, orderTotal, extras);
          return;
        }

        if (data.requires_action) {
          const clientSecret = data.payment_intent_client_secret;
          const actionResult = await stripe.handleCardAction(clientSecret);

          if (actionResult.error) {
            errorEl.textContent = actionResult.error.message || '3D Secure failed';
            setLoading(false);
            return;
          }

          // Confirm endpoint differs by flow:
          //   one-time card → /api/checkout-confirm (just payment_intent_id)
          //   monthly card → /api/checkout-subscription-confirm (full stashed params)
          let confirmBody: Record<string, unknown>;
          let confirmEndpoint: string;
          if (isMonthly) {
            confirmEndpoint = '/api/checkout-subscription-confirm';
            confirmBody = {
              payment_intent_id: actionResult.paymentIntent.id,
              order_number: data.order_number,
              customer_id: data.customer_id,
              payment_method_id: data.payment_method_id,
              first_payment_date: data.first_payment_date,
              course_ids: getCartCourseIds(),
              customer_name: `${firstName} ${lastName}`,
              customer_email: email,
              customer_phone: phone,
            };
          } else {
            confirmEndpoint = '/api/checkout-confirm';
            confirmBody = { payment_intent_id: actionResult.paymentIntent.id };
          }

          const confirmResponse = await fetch(confirmEndpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(confirmBody),
          });

          const confirmData = await confirmResponse.json();

          if (confirmData.success) {
            const orderTotal = isMonthly ? (20 + installmentDisplay * 12) : total;
            const extras: Record<string, unknown> = {};
            if (isMonthly) {
              extras.registration_fee = 20;
              extras.monthly_amount = installmentDisplay;
              extras.first_payment_date = firstPaymentDateInput.value;
              extras.payment_method = 'card';
            }
            storeOrderAndRedirect(confirmData.order_number, firstName, lastName, email, orderTotal, extras);
            return;
          }

          errorEl.textContent = confirmData.error || 'Payment failed. Please try again.';
          setLoading(false);
          return;
        }

        errorEl.textContent = data.error || 'Payment failed. Please try again or call us on 0121 690 9563 for assistance.';
        setLoading(false);
      } catch {
        errorEl.textContent = 'An error occurred. Please try again or call us on 0121 690 9563 for assistance.';
        setLoading(false);
      }
    });
  });
</script>
