---
export const prerender = true;

import { getCollection } from 'astro:content';
import ServiceLayout from '../../layouts/ServiceLayout.astro';
import Hero from '../../components/Hero.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import FAQ from '../../components/FAQ.astro';
import CTA from '../../components/CTA.astro';
import Testimonials from '../../components/Testimonials.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import GradientMesh from '../../components/GradientMesh.astro';
import ServiceSchema from '../../components/schemas/ServiceSchema.astro';
import { siteConfig } from '../../data/site-config';

export async function getStaticPaths() {
  const services = await getCollection('services');
  return services.map((service) => ({
    params: { slug: service.data.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const { data } = service;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Courses', href: '/courses' },
  { label: data.title, href: `/courses/${data.slug}` },
];

const relatedServices = siteConfig.services.filter((s) => s.slug !== data.slug).slice(0, 3);

const serviceImages: Record<string, { thumbnail: string; thumbnailAlt: string }> = {
  'health-social-care': { thumbnail: '/images/courses/health-social/hs-thumb.webp', thumbnailAlt: 'Care worker supporting elderly resident in UK care home' },
  'accounting': { thumbnail: '/images/courses/accounting/acc-thumb.webp', thumbnailAlt: 'Student studying AAT accounting course with financial documents' },
  'occupational-studies': { thumbnail: '/images/courses/occupational/occ-thumb.webp', thumbnailAlt: 'Professional completing workplace skills training online' },
  'functional-skills': { thumbnail: '/images/courses/functional-skills/func-thumb.webp', thumbnailAlt: 'Adult learner studying Functional Skills Maths on tablet device' },
  'security-stewarding': { thumbnail: '/images/courses/security/sec-thumb.webp', thumbnailAlt: 'Door supervisor in high-visibility vest at venue entrance' },
  'business-management': { thumbnail: '/images/courses/business/bus-thumb.webp', thumbnailAlt: 'Team leader facilitating a workplace meeting with colleagues' },
  'digital-technology': { thumbnail: '/images/courses/digital-technology/dt-thumb.webp', thumbnailAlt: 'Cyber security professional monitoring network security dashboards' },
  'teaching-qualification': { thumbnail: '/images/courses/teaching/teach-thumb.webp', thumbnailAlt: 'Teacher leading a classroom session with adult learners' },
  'access-to-he': { thumbnail: '/images/courses/access-to-he/access-thumb.webp', thumbnailAlt: 'Mature student studying online Access to HE course on laptop' },
};
---

<ServiceLayout title={data.metaTitle} description={data.metaDescription}>
  <ServiceSchema name={data.title} description={data.shortDescription} url={`/courses/${data.slug}`} />

  <Breadcrumb items={breadcrumbs} />

  <Hero
    heading={data.heroHeading}
    subheading={data.heroSubheading}
    variant="inner"
    image={data.thumbnail}
    imageAlt={data.thumbnailAlt}
  />

  <!-- Above-fold CTA -->
  <div class="bg-primary-50 py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-neutral-700 font-medium text-sm sm:text-base">Ready to get started? Speak to our admissions team for free course advice.</p>
      <a
        href="/contact"
        class="btn-primary bg-gradient-to-r from-primary-500 to-primary-600 text-white px-6 py-2.5 rounded-xl font-semibold text-sm shadow-brand hover:shadow-brand-lg hover:-translate-y-0.5 active:translate-y-0 active:shadow-brand transition-all duration-300 flex-shrink-0"
      >
        Enquire Now
      </a>
    </div>
  </div>

  <!-- Introduction -->
  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-lg md:text-xl text-neutral-600 leading-relaxed">
          {data.longDescription}
        </p>
      </div>
    </div>
  </section>

  <!-- Benefits -->
  <section class="py-10 lg:py-14 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading font-display font-bold text-3xl md:text-4xl text-neutral-900 mb-8">
        Why Study <span class="text-primary-500">{data.title}</span>?
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {data.benefits.map((benefit, index) => (
          <div class="flex gap-4 items-start p-6 bg-white rounded-2xl shadow-brand-sm hover:shadow-brand transition-all duration-300 hover:-translate-y-1">
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-primary-500 to-primary-600 shadow-brand flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
            </div>
            <p class="text-neutral-700 font-medium">{benefit}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Course Listings -->
  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8">
        <h2 class="section-heading font-display font-bold text-3xl md:text-4xl lg:text-5xl text-neutral-900 mb-6">
          Available <span class="text-primary-500">Courses</span>
        </h2>
        <p class="text-lg text-neutral-600 max-w-2xl mx-auto">
          Choose the course level that matches your experience and career goals.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 courses-grid">
        {data.courses.map((course) => (
          <div class="course-card group bg-white rounded-2xl overflow-hidden shadow-brand-sm hover:shadow-brand-lg border border-neutral-100 hover:border-primary-200 transition-all duration-300 hover:-translate-y-1">
            {course.image && (
              <a href={`/course/${course.image?.split('/').pop()?.replace(/\.(webp|png|jpg)$/, '') || ''}`} class="block relative aspect-[16/9] overflow-hidden">
                <div class="absolute inset-0 animate-pulse bg-neutral-200"></div>
                <img
                  src={course.image}
                  alt={course.name}
                  width="400"
                  height="225"
                  class="relative z-10 w-full h-full object-contain transition-transform duration-500 group-hover:scale-105"
                  loading="lazy"
                />
              </a>
            )}
            <div class="p-6">
              <!-- Level badge -->
              <div class="flex items-center gap-2 mb-3">
                <span class="text-xs font-bold text-primary-600 bg-primary-50 px-3 py-1 rounded-full">{course.level}</span>
                <span class="text-xs font-medium text-neutral-400 bg-neutral-100 px-3 py-1 rounded-full">{course.accreditor}</span>
              </div>

              <h3 class="font-display font-bold text-lg text-neutral-900 mb-2 group-hover:text-primary-600 transition-colors duration-300 leading-tight">
                <a href={`/course/${course.image?.split('/').pop()?.replace(/\.(webp|png|jpg)$/, '') || ''}`} class="hover:text-primary-600">
                  {course.name}
                </a>
              </h3>
              <p class="text-sm text-neutral-600 leading-relaxed mb-4">
                {course.description}
              </p>

              <div class="grid grid-cols-3 gap-2 pt-4 border-t border-neutral-100 mb-4">
                <div>
                  <p class="text-xs text-neutral-400">Duration</p>
                  <p class="text-sm font-semibold text-neutral-700">{course.duration}</p>
                </div>
                <div class="text-center">
                  <p class="text-xs text-neutral-400">Online</p>
                  <p class="text-lg font-bold text-primary-600">{course.price}</p>
                </div>
                {course.tutorPrice && (
                  <div class="text-right">
                    <p class="text-xs text-neutral-400">Tutor-Led</p>
                    <p class="text-sm font-semibold text-neutral-700">{course.tutorPrice}</p>
                  </div>
                )}
              </div>

              <div class="flex gap-2">
                <a
                  href={`/course/${course.image?.split('/').pop()?.replace(/\.(webp|png|jpg)$/, '') || ''}`}
                  class="flex-1 text-center bg-gradient-to-r from-primary-500 to-primary-600 text-white px-4 py-2.5 rounded-xl font-semibold text-sm shadow-brand hover:shadow-brand-lg hover:-translate-y-0.5 active:translate-y-0 transition-all duration-300"
                >
                  View Details
                </a>
                {course.price.includes('Contact') || course.price.includes('Enquir') ? (
                  <a
                    href="/contact"
                    class="px-4 py-2.5 rounded-xl font-semibold text-sm border border-primary-200 text-primary-600 hover:bg-primary-50 transition-all duration-300"
                  >
                    Enquire
                  </a>
                ) : (
                  <button
                    class="add-to-cart-btn px-4 py-2.5 rounded-xl font-semibold text-sm border border-neutral-200 text-neutral-700 hover:border-primary-200 hover:text-primary-600 transition-all duration-300"
                    data-course-id={course.image?.split('/').pop()?.replace(/\.(webp|png|jpg)$/, '') || ''}
                  >
                    Add to Cart
                  </button>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Mid-page CTA -->
  <CTA
    heading="Ready to Enrol?"
    subheading={`Speak to our team about starting your ${data.title} course today. We're here to answer your questions and help you choose the right level.`}
    ctaText="Enquire Now"
    ctaHref="/contact"
  />

  <!-- Testimonials -->
  <Testimonials title={`Student Reviews`} />

  <!-- FAQs -->
  {data.faqs.length > 0 && (
    <FAQ faqs={data.faqs} title={`${data.title} FAQs`} accentWord="FAQs" />
  )}

  <!-- Related Services -->
  <section class="py-12 lg:py-16 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="section-heading font-display font-bold text-3xl md:text-4xl text-neutral-900 mb-8 text-center">
        Explore Other <span class="text-primary-500">Categories</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {relatedServices.map((s) => {
          const images = serviceImages[s.slug];
          return (
            <a
              href={`/courses/${s.slug}`}
              class="service-card group block rounded-2xl overflow-hidden shadow-brand-sm hover:shadow-brand-lg bg-white border border-neutral-100 transition-all duration-300"
            >
              <div class="card-accent-bar bg-gradient-to-r from-primary-500 to-accent-500 rounded-t-2xl"></div>
              {images && (
                <div class="h-40 overflow-hidden">
                  <img
                    src={images.thumbnail}
                    alt={images.thumbnailAlt}
                    width="400"
                    height="250"
                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                    loading="lazy"
                  />
                </div>
              )}
              <div class="p-6">
                <h3 class="font-display font-bold text-lg text-neutral-900 group-hover:text-primary-600 transition-colors duration-300 mb-2">{s.name}</h3>
                <p class="text-sm text-neutral-600">{s.shortDescription}</p>
                <span class="inline-flex items-center gap-2 text-primary-500 font-semibold text-sm mt-4">
                  View Courses
                  <svg class="w-4 h-4 card-arrow" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <CTA
    heading="Take the Next Step"
    subheading="Invest in yourself today. Our team is ready to help you start your learning journey."
    ctaText="Contact Us"
    ctaHref="/contact"
    variant="dramatic"
  />

  <SectionDivider fillColor="#0f172a" variant="curve" />
</ServiceLayout>

<script>
  import { addToCart, isInCart } from '../../lib/cart';
  import { COURSES } from '../../data/courses';

  document.addEventListener('astro:page-load', () => {
    // Add to cart buttons
    document.querySelectorAll('.add-to-cart-btn').forEach((btn) => {
      const courseId = (btn as HTMLElement).dataset.courseId || '';
      if (!courseId || !COURSES[courseId]) {
        // Hide button if no matching course in data
        (btn as HTMLElement).style.display = 'none';
        return;
      }

      // Check if already in cart
      if (isInCart(courseId)) {
        btn.textContent = 'In Cart';
        (btn as HTMLElement).classList.add('opacity-60');
      }

      btn.addEventListener('click', () => {
        if (isInCart(courseId)) {
          window.location.href = '/cart';
          return;
        }
        addToCart(courseId);
        btn.textContent = 'Added!';
        (btn as HTMLElement).classList.add('opacity-60');
        setTimeout(() => {
          btn.textContent = 'In Cart';
        }, 1500);
      });
    });

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    // @ts-ignore
    if (typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
    // @ts-ignore
    gsap.registerPlugin(ScrollTrigger);

    // Only animate if cards are visible and grid exists
    const courseCards = document.querySelectorAll('.course-card');
    if (courseCards.length === 0) return;

    // @ts-ignore
    gsap.set('.course-card', { y: 40, opacity: 0 });
    // @ts-ignore
    gsap.to('.course-card',
      { // @ts-ignore
        scrollTrigger: { trigger: '.courses-grid', start: 'top 85%' },
        y: 0, opacity: 1,
        duration: 0.5,
        stagger: 0.08,
        ease: 'power2.out',
        onComplete: () => {
          // Ensure all cards are visible after animation
          courseCards.forEach((card) => {
            (card as HTMLElement).style.opacity = '1';
            (card as HTMLElement).style.transform = 'none';
          });
        },
      }
    );

    // Fallback: if cards are still invisible after 3s, force show them
    setTimeout(() => {
      courseCards.forEach((card) => {
        if (getComputedStyle(card).opacity === '0') {
          (card as HTMLElement).style.opacity = '1';
          (card as HTMLElement).style.transform = 'none';
        }
      });
    }, 3000);
  });
</script>
