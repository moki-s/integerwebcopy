---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTA from '../../components/CTA.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import { COURSES, getAllCourses, categoryToSlug } from '../../data/courses';
import { siteConfig } from '../../data/site-config';

const allCourses = getAllCourses();
const categories = [...new Set(allCourses.map((c) => c.category))];

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Courses', href: '/courses' },
];
---

<BaseLayout
  title="All Courses | Browse 45+ Accredited Online Qualifications | Integer Training"
  description="Browse all 45+ accredited online courses. Filter by category, search by keyword, and sort by price or popularity. Nationally recognised qualifications with tutor support."
>
  <Breadcrumb items={breadcrumbs} />

  <!-- Hero -->
  <section class="bg-gradient-to-br from-neutral-900 via-neutral-800 to-neutral-900 text-white py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="font-display font-bold text-3xl md:text-4xl lg:text-5xl mb-4">All Courses</h1>
      <p class="text-neutral-300 text-lg max-w-2xl">Browse our accredited qualifications and find the right course for your career goals.</p>
    </div>
  </section>

  <!-- Trust Bar -->
  <div class="bg-white border-b border-neutral-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm">
        <div class="flex items-center gap-2 text-neutral-700">
          <svg class="w-5 h-5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          <span class="font-semibold">Ofqual Regulated</span>
        </div>
        <div class="flex items-center gap-2 text-neutral-700">
          <svg class="w-5 h-5 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          <span class="font-semibold">{siteConfig.stats.trustpilotRating}/5 Trustpilot</span>
        </div>
        <div class="flex items-center gap-2 text-neutral-700">
          <svg class="w-5 h-5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          <span class="font-semibold">0% Finance</span>
        </div>
        <div class="flex items-center gap-2 text-neutral-700">
          <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          <span class="font-semibold">Tutor Support</span>
        </div>
      </div>
    </div>
  </div>

  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-4 lg:gap-8">
        <!-- Sidebar Filters -->
        <aside class="lg:col-span-1 mb-8 lg:mb-0">
          <!-- Mobile filter toggle -->
          <button
            id="filter-toggle"
            class="lg:hidden w-full flex items-center justify-between bg-neutral-100 px-4 py-3 rounded-xl font-semibold text-sm mb-4"
          >
            <span class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" /></svg>
              Filters
            </span>
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </button>

          <div id="filter-panel" class="hidden lg:block space-y-6">
            <!-- Search -->
            <div>
              <label for="course-search" class="block text-sm font-semibold text-neutral-700 mb-2">Search</label>
              <input
                type="text"
                id="course-search"
                placeholder="Search courses..."
                class="w-full px-4 py-2.5 rounded-xl border border-neutral-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent"
              />
            </div>

            <!-- Categories -->
            <div>
              <h3 class="text-sm font-semibold text-neutral-700 mb-3">Categories</h3>
              <div class="space-y-2">
                <label class="flex items-center gap-2 cursor-pointer text-sm font-semibold text-neutral-800 hover:text-neutral-900 pb-2 mb-1 border-b border-neutral-100">
                  <input type="checkbox" id="select-all-cats" class="rounded border-neutral-300 text-primary-500 focus:ring-primary-500" checked />
                  <span>Select All</span>
                </label>
                {categories.map((cat) => {
                  const count = allCourses.filter((c) => c.category === cat).length;
                  return (
                    <label class="flex items-center gap-2 cursor-pointer text-sm text-neutral-600 hover:text-neutral-900">
                      <input type="checkbox" class="category-filter rounded border-neutral-300 text-primary-500 focus:ring-primary-500" value={cat} checked />
                      <span>{cat}</span>
                      <span class="text-xs text-neutral-400 ml-auto">({count})</span>
                    </label>
                  );
                })}
              </div>
            </div>

            <!-- Sort -->
            <div>
              <h3 class="text-sm font-semibold text-neutral-700 mb-3">Sort By</h3>
              <select id="course-sort" class="w-full px-4 py-2.5 rounded-xl border border-neutral-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent bg-white">
                <option value="popularity">Popularity</option>
                <option value="price-asc">Price: Low to High</option>
                <option value="price-desc">Price: High to Low</option>
              </select>
            </div>
          </div>
        </aside>

        <!-- Course Grid -->
        <div class="lg:col-span-3">
          <div class="flex items-center justify-between mb-6">
            <p id="results-count" class="text-sm text-neutral-500">Showing {allCourses.length} courses</p>
          </div>

          <div id="course-grid" class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-6">
            {allCourses
              .sort((a, b) => b.students - a.students)
              .map((course) => (
                <div
                  class="course-item group bg-white rounded-2xl overflow-hidden shadow-brand-sm hover:shadow-brand-lg border border-neutral-100 hover:border-primary-200 transition-all duration-300 hover:-translate-y-1"
                  data-category={course.category}
                  data-price={course.price}
                  data-students={course.students}
                  data-title={course.title.toLowerCase()}
                >
                  <a href={`/course/${course.id}`} class="block">
                    <div class="relative h-40 overflow-hidden bg-neutral-100">
                      <img
                        src={course.image}
                        alt={course.title}
                        width="400"
                        height="250"
                        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
                        loading="lazy"
                        onerror="this.onerror=null;this.style.display='none';this.parentElement.innerHTML+='<div class=\'flex items-center justify-center w-full h-full absolute inset-0 bg-neutral-100\'><svg class=\'w-12 h-12 text-neutral-300\' fill=\'none\' stroke=\'currentColor\' viewBox=\'0 0 24 24\'><path stroke-linecap=\'round\' stroke-linejoin=\'round\' stroke-width=\'1.5\' d=\'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253\' /></svg></div>'"
                      />
                      <!-- Student count badge overlay -->
                      <div class="absolute top-2 right-2 bg-white/90 backdrop-blur-sm rounded-full px-2.5 py-1 text-[10px] font-bold text-neutral-700 flex items-center gap-1">
                        <svg class="w-3 h-3 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                        {course.students.toLocaleString()}+
                      </div>
                    </div>
                    <div class="p-5">
                      <div class="text-xs text-neutral-400 uppercase tracking-wider mb-1">{course.category}</div>
                      <h3 class="font-display font-bold text-neutral-900 group-hover:text-primary-600 transition-colors duration-300 mb-2 leading-tight text-sm">
                        {course.title}
                      </h3>
                      <span
                        class="inline-block text-[10px] font-bold px-2 py-0.5 rounded-full text-white mb-3"
                        style={`background-color: ${course.badgeColor};`}
                      >
                        {course.badge}
                      </span>
                      <div class="flex items-center justify-between pt-3 border-t border-neutral-100">
                        <div>
                          {course.isEnquiryOnly ? (
                            <span class="text-sm font-semibold text-neutral-600">Contact for pricing</span>
                          ) : (
                            <>
                              <span class="text-xs text-neutral-400 line-through">&pound;{course.oldPrice}</span>
                              <span class="text-lg font-bold text-primary-600 ml-1">&pound;{course.price}</span>
                            </>
                          )}
                        </div>
                        <span class="text-xs text-primary-500 font-semibold">View &rarr;</span>
                      </div>
                    </div>
                  </a>
                  <div class="px-5 pb-4 -mt-1">
                    <a href={`/course/${course.id}#enquiry-section`} class="text-xs text-primary-500 hover:text-primary-600 font-semibold transition-colors flex items-center gap-1">
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg>
                      Get Course Advice
                    </a>
                  </div>
                </div>
              ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTA
    heading="Don't Put Your Career on Hold"
    subheading="The right qualification could be weeks away. Let's get started."
    ctaText="Enrol Today"
    ctaHref="/contact"
    variant="dramatic"
  />

  <SectionDivider fillColor="#0f172a" variant="curve" />
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    const grid = document.getElementById('course-grid');
    const searchInput = document.getElementById('course-search') as HTMLInputElement;
    const sortSelect = document.getElementById('course-sort') as HTMLSelectElement;
    const categoryCheckboxes = document.querySelectorAll('.category-filter') as NodeListOf<HTMLInputElement>;
    const resultsCount = document.getElementById('results-count');
    const filterToggle = document.getElementById('filter-toggle');
    const filterPanel = document.getElementById('filter-panel');

    if (!grid) return;

    // Select All checkbox
    const selectAllCb = document.getElementById('select-all-cats') as HTMLInputElement;

    selectAllCb?.addEventListener('change', () => {
      categoryCheckboxes.forEach((cb) => (cb.checked = selectAllCb.checked));
      filterAndSort();
    });

    // Keep "Select All" in sync when individual checkboxes change
    categoryCheckboxes.forEach((cb) => {
      cb.addEventListener('change', () => {
        const allChecked = Array.from(categoryCheckboxes).every((c) => c.checked);
        const noneChecked = Array.from(categoryCheckboxes).every((c) => !c.checked);
        selectAllCb.checked = allChecked;
        selectAllCb.indeterminate = !allChecked && !noneChecked;
      });
    });

    // Mobile filter toggle
    filterToggle?.addEventListener('click', () => {
      filterPanel?.classList.toggle('hidden');
    });

    function filterAndSort() {
      const search = searchInput?.value.toLowerCase().trim() || '';
      const selectedCategories = Array.from(categoryCheckboxes)
        .filter((cb) => cb.checked)
        .map((cb) => cb.value);
      const sortBy = sortSelect?.value || 'popularity';

      const items = Array.from(grid!.querySelectorAll('.course-item')) as HTMLElement[];

      // Filter
      let visibleCount = 0;
      items.forEach((item) => {
        const title = item.dataset.title || '';
        const category = item.dataset.category || '';
        const matchesSearch = !search || title.includes(search) || category.toLowerCase().includes(search);
        const matchesCategory = selectedCategories.length === 0 || selectedCategories.includes(category);

        if (matchesSearch && matchesCategory) {
          item.style.display = '';
          visibleCount++;
        } else {
          item.style.display = 'none';
        }
      });

      // Sort visible items
      const visibleItems = items.filter((item) => item.style.display !== 'none');
      visibleItems.sort((a, b) => {
        if (sortBy === 'price-asc') return Number(a.dataset.price) - Number(b.dataset.price);
        if (sortBy === 'price-desc') return Number(b.dataset.price) - Number(a.dataset.price);
        return Number(b.dataset.students) - Number(a.dataset.students); // popularity
      });

      // Reorder DOM
      visibleItems.forEach((item) => grid!.appendChild(item));
      // Append hidden items at end
      items.filter((item) => item.style.display === 'none').forEach((item) => grid!.appendChild(item));

      if (resultsCount) {
        resultsCount.textContent = `Showing ${visibleCount} course${visibleCount !== 1 ? 's' : ''}`;
      }
    }

    searchInput?.addEventListener('input', filterAndSort);
    sortSelect?.addEventListener('change', filterAndSort);
    categoryCheckboxes.forEach((cb) => cb.addEventListener('change', filterAndSort));
  });
</script>
