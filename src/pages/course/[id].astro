                  <svg class="w-4 h-4 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z" /></svg>
                  Cert. Included
                </div>
              </div>

              <!-- Social Proof -->
              <div class="border-t border-neutral-100 px-6 py-4">
                <div class="bg-primary-50 rounded-xl p-4 mb-3">
                  <div class="flex items-center gap-1 mb-2">
                    {[1,2,3,4,5].map(() => (
                      <svg class="w-4 h-4 text-accent-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
                    ))}
                  </div>
                  <p class="text-sm text-neutral-800 italic">"The tutor support was fantastic. I completed my qualification while working full-time."</p>
                  <p class="text-xs text-neutral-600 mt-1 font-semibold">- Verified Student, Trustpilot</p>
                </div>
                <div class="flex items-center gap-2 text-xs text-neutral-600">
                  <svg class="w-4 h-4 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                  <span class="font-semibold">{course.students.toLocaleString()}+ students enrolled this year</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Integer Training (competitor-inspired "Why learn with us") -->
  <section class="py-12 bg-neutral-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display font-bold text-2xl md:text-3xl text-neutral-900 mb-8 text-center">Why Choose Integer Training</h2>
      <div class="grid grid-cols-2 lg:grid-cols-5 gap-4">
        <div class="bg-white rounded-xl border border-neutral-100 p-5 text-center hover:border-primary-200 transition-colors">
          <div class="w-12 h-12 mx-auto mb-3 bg-primary-50 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
          </div>
          <h4 class="font-bold text-neutral-900 text-sm mb-1">Ofqual Regulated</h4>
          <p class="text-xs text-neutral-600">Nationally recognised qualifications</p>
        </div>
        <div class="bg-white rounded-xl border border-neutral-100 p-5 text-center hover:border-primary-200 transition-colors">
          <div class="w-12 h-12 mx-auto mb-3 bg-primary-50 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </div>
          <h4 class="font-bold text-neutral-900 text-sm mb-1">Expert Tutors</h4>
          <p class="text-xs text-neutral-600">Dedicated 1-to-1 support</p>
        </div>
        <div class="bg-white rounded-xl border border-neutral-100 p-5 text-center hover:border-primary-200 transition-colors">
          <div class="w-12 h-12 mx-auto mb-3 bg-primary-50 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          </div>
          <h4 class="font-bold text-neutral-900 text-sm mb-1">0% Finance</h4>
          <p class="text-xs text-neutral-600">Interest-free payment plans</p>
        </div>
        <div class="bg-white rounded-xl border border-neutral-100 p-5 text-center hover:border-primary-200 transition-colors">
          <div class="w-12 h-12 mx-auto mb-3 bg-primary-50 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-primary-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
          </div>
          <h4 class="font-bold text-neutral-900 text-sm mb-1">{siteConfig.stats.trustpilotRating}/5 Rated</h4>
          <p class="text-xs text-neutral-600">Trustpilot verified reviews</p>
        </div>
        <div class="bg-white rounded-xl border border-neutral-100 p-5 text-center hover:border-primary-200 transition-colors col-span-2 lg:col-span-1">
          <div class="w-12 h-12 mx-auto mb-3 bg-primary-50 rounded-xl flex items-center justify-center">
            <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          </div>
          <h4 class="font-bold text-neutral-900 text-sm mb-1">Start Today</h4>
          <p class="text-xs text-neutral-600">Enrol and begin instantly</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Courses -->
  {relatedCourses.length > 0 && (
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="font-display font-bold text-2xl md:text-3xl text-neutral-900 mb-8">
          More <span class="text-primary-500">{course.category}</span> Courses
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedCourses.map((rc) => (
            <a href={`/course/${rc.id}`} class="group bg-white rounded-2xl overflow-hidden shadow-brand-sm hover:shadow-brand-lg border border-neutral-100 hover:border-primary-200 transition-all duration-300 hover:-translate-y-1">
              <div class="p-6">
                <span class="text-xs font-bold px-2 py-0.5 rounded-full text-white mb-3 inline-block" style={`background-color: ${rc.badgeColor};`}>{rc.badge}</span>
                <h3 class="font-display font-bold text-neutral-900 group-hover:text-primary-600 transition-colors mb-2">{rc.title}</h3>
                <div class="flex items-center justify-between pt-3 border-t border-neutral-100 mt-3">
                  <span class="text-sm text-neutral-400 line-through">&pound;{rc.oldPrice}</span>
                  <span class="text-lg font-bold text-primary-600">&pound;{rc.price}</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <Testimonials title="What Our Students Say" />

  <CTA
    heading="Ready to Get Started?"
    subheading={`Enrol on the ${course.title} today and take the next step in your career. Our team is here to help.`}
    ctaText="Enquire Now"
    ctaHref="/contact"
    variant="dramatic"
  />

  <SectionDivider fillColor="#0f172a" variant="curve" />

  <!-- Desktop Sticky CTA Bar (hidden on mobile - mobile has its own) -->
  <div id="sticky-cta-bar" class="hidden lg:block fixed bottom-0 left-0 right-0 z-40 translate-y-full transition-transform duration-300 bg-white border-t border-neutral-200 shadow-[0_-4px_20px_rgba(0,0,0,0.1)]">
    <div class="max-w-7xl mx-auto px-4 py-3 flex items-center justify-between gap-4">
      <div class="min-w-0 flex-1">
        <p class="font-bold text-neutral-900 text-sm truncate">{course.title}</p>
        <div class="flex items-center gap-2">
          <span id="desktop-sticky-price" class="text-primary-600 font-bold text-lg">&pound;{course.price}</span>
          <span id="desktop-sticky-label" class="text-xs text-neutral-500">{course.onlinePriceLabel ? onlineLabel : 'Online'}</span>
        </div>
      </div>
      <div class="flex items-center gap-3 flex-shrink-0">
        <a
          href="#enquiry-section"
          class="bg-white border-2 border-neutral-900 text-neutral-900 font-bold px-6 py-2.5 rounded-xl text-sm hover:bg-neutral-50 transition-colors"
        >
          Enquire Now
        </a>
        <button
          id="sticky-add-to-cart"
          class="bg-gradient-to-r from-primary-500 to-primary-600 text-white font-bold px-6 py-2.5 rounded-xl text-sm shadow-brand hover:shadow-brand-lg transition-all duration-300"
          data-course-id={course.id}
        >
          Add to Basket - &pound;{course.price}
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Sticky Buy Bar (always visible on scroll, competitor-style) -->
  <div id="mobile-sticky-bar" class="lg:hidden fixed bottom-0 left-0 right-0 z-40 translate-y-full transition-transform duration-300 bg-white border-t border-neutral-200 shadow-[0_-4px_20px_rgba(0,0,0,0.1)]" style="padding-bottom: env(safe-area-inset-bottom, 0px);">
    <div class="px-4 py-3">
      <div class="flex items-center gap-2">
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-1">
            <span id="mobile-sticky-price" class="text-neutral-900 font-bold text-lg">&pound;{course.price}</span>
            <span id="mobile-sticky-label" class="text-[10px] text-neutral-500">{course.onlinePriceLabel ? onlineLabel : 'Online'}</span>
          </div>
          <p id="mobile-sticky-monthly" class="text-xs text-neutral-500" data-online-monthly={installmentPrice}>or &pound;{installmentPrice.toFixed(2)}/mo</p>
        </div>
        <a
          href="#enquiry-section"
          class="bg-white border-2 border-neutral-900 text-neutral-900 font-bold px-4 py-2.5 rounded-xl text-sm flex-shrink-0"
        >
          Enquire
        </a>
        <button
          id="mobile-sticky-add-to-cart"
          class="bg-gradient-to-r from-primary-500 to-primary-600 text-white font-bold px-4 py-2.5 rounded-xl text-sm shadow-brand flex-shrink-0"
          data-course-id={course.id}
        >
          Add to Basket
        </button>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  import { addToCart, isInCart } from '../../lib/cart';

  document.addEventListener('astro:page-load', () => {
    // --- UTM Capture ---
    const params = new URLSearchParams(window.location.search);
    const utmSource = params.get('utm_source') || '';
    const utmCampaign = params.get('utm_campaign') || '';
    document.querySelectorAll('.utm-source').forEach((el) => (el as HTMLInputElement).value = utmSource);
    document.querySelectorAll('.utm-campaign').forEach((el) => (el as HTMLInputElement).value = utmCampaign);

    // --- Tabs ---
    const tabBtns = document.querySelectorAll('.tab-btn');
    const tabPanels = document.querySelectorAll('.tab-panel');

    tabBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const tab = (btn as HTMLElement).dataset.tab;
        tabBtns.forEach((b) => {
          b.classList.remove('border-primary-500', 'text-primary-600');
          b.classList.add('border-transparent', 'text-neutral-500');
          b.setAttribute('aria-selected', 'false');
        });
        btn.classList.add('border-primary-500', 'text-primary-600');
        btn.classList.remove('border-transparent', 'text-neutral-500');
        btn.setAttribute('aria-selected', 'true');

        tabPanels.forEach((panel) => {
          if (panel.id === `tab-${tab}`) {
            panel.classList.remove('hidden');
          } else {
            panel.classList.add('hidden');
          }
        });
      });
    });

    // --- Pricing Tier Selection ---
    const pricingOptions = document.querySelectorAll('.pricing-option');
    const addBtn = document.getElementById('sidebar-add-to-cart') as HTMLButtonElement;
    const viewCartLink = document.getElementById('sidebar-view-cart') as HTMLAnchorElement;

    pricingOptions.forEach((option) => {
      option.addEventListener('click', () => {
        // Deselect all
        pricingOptions.forEach((opt) => {
          opt.classList.remove('bg-primary-50', 'border-primary-500');
          opt.classList.add('bg-neutral-50', 'border-neutral-200');
          const radio = opt.querySelector('.pricing-radio') as HTMLElement;
          if (radio) {
            radio.classList.remove('bg-primary-500');
            radio.classList.add('bg-transparent');
          }
          const ring = radio?.parentElement as HTMLElement;
          if (ring) {
            ring.classList.remove('border-primary-500');
            ring.classList.add('border-neutral-300');
          }
        });
        // Select clicked
        option.classList.remove('bg-neutral-50', 'border-neutral-200');
        option.classList.add('bg-primary-50', 'border-primary-500');
        const radio = option.querySelector('.pricing-radio') as HTMLElement;
        if (radio) {
          radio.classList.remove('bg-transparent');
          radio.classList.add('bg-primary-500');
        }
        const ring = radio?.parentElement as HTMLElement;
        if (ring) {
          ring.classList.remove('border-neutral-300');
          ring.classList.add('border-primary-500');
        }
        // Update all price displays to match selected tier
        const price = (option as HTMLElement).dataset.tierPrice || '';
        const label = (option as HTMLElement).dataset.tierLabel || '';
        const monthly = label === 'Tutor-Led'
          ? Math.round(((parseFloat(price) - 50) / 12) * 100) / 100
          : parseFloat((document.querySelector('#price-full')?.closest('.pricing-option') as HTMLElement)?.dataset.tierPrice || price);
        const onlineMonthly = parseFloat(addBtn?.dataset.courseMonthly || '0');

        if (addBtn && price) {
          addBtn.dataset.coursePrice = price;
          addBtn.textContent = `Add to Basket — £${price} (${label})`;
        }
        // Update mobile sticky bar
        const mobilePrice = document.getElementById('mobile-sticky-price');
        const mobileLabel = document.getElementById('mobile-sticky-label');
        const mobileMonthly = document.getElementById('mobile-sticky-monthly');
        if (mobilePrice) mobilePrice.textContent = `£${price}`;
        if (mobileLabel) mobileLabel.textContent = label;
        if (mobileMonthly) {
          const mo = label === 'Tutor-Led'
            ? (Math.round(((parseFloat(price) - 50) / 12) * 100) / 100).toFixed(2)
            : mobileMonthly.dataset.onlineMonthly || '0';
          mobileMonthly.textContent = `or £${mo}/mo`;
        }
        // Update desktop sticky bar
        const desktopPrice = document.getElementById('desktop-sticky-price');
        const desktopLabel = document.getElementById('desktop-sticky-label');
        if (desktopPrice) desktopPrice.textContent = `£${price}`;
        if (desktopLabel) desktopLabel.textContent = label;
      });
    });

    // --- Add to Cart (sidebar) ---
    if (addBtn) {
      const courseId = addBtn.dataset.courseId || '';

      if (isInCart(courseId)) {
        addBtn.classList.add('hidden');
        viewCartLink?.classList.remove('hidden');
      }

      addBtn.addEventListener('click', () => {
        addToCart(courseId);
        addBtn.textContent = 'Added!';
        setTimeout(() => {
          addBtn.classList.add('hidden');
          viewCartLink?.classList.remove('hidden');
        }, 800);
      });
    }

    // --- Add to Cart (all sticky bars) ---
    const stickyBtns = document.querySelectorAll('#sticky-add-to-cart, #mobile-sticky-add-to-cart') as NodeListOf<HTMLButtonElement>;
    stickyBtns.forEach((stickyBtn) => {
      const courseId = stickyBtn.dataset.courseId || '';

      if (isInCart(courseId)) {
        stickyBtn.textContent = 'In Basket';
        stickyBtn.disabled = true;
        stickyBtn.classList.add('opacity-60');
      }

      stickyBtn.addEventListener('click', () => {
        addToCart(courseId);
        stickyBtn.textContent = 'Added!';
        stickyBtn.disabled = true;
        stickyBtn.classList.add('opacity-60');
        // Sync sidebar button too
        if (addBtn) {
          addBtn.classList.add('hidden');
          viewCartLink?.classList.remove('hidden');
        }
        // Sync all sticky buttons
        stickyBtns.forEach((b) => {
          b.textContent = 'Added!';
          b.disabled = true;
          b.classList.add('opacity-60');
        });
        setTimeout(() => {
          stickyBtns.forEach((b) => { b.textContent = 'In Basket'; });
        }, 800);
      });
    });

    // --- Sticky CTA Bars ---
    const stickyBar = document.getElementById('sticky-cta-bar');
    const mobileStickyBar = document.getElementById('mobile-sticky-bar');
    const sidebar = document.getElementById('sidebar-pricing');

    // Desktop: use IntersectionObserver on sidebar pricing card
    if (sidebar && stickyBar) {
      const desktopObserver = new IntersectionObserver(
        ([entry]) => {
          if (entry.isIntersecting) {
            stickyBar.classList.add('translate-y-full');
          } else {
            stickyBar.classList.remove('translate-y-full');
          }
        },
        { threshold: 0 }
      );
      desktopObserver.observe(sidebar);
    }

    // Mobile: show after scrolling past 500px (hero area)
    if (mobileStickyBar) {
      const handleMobileScroll = () => {
        if (window.innerWidth >= 1024) return; // skip on desktop
        if (window.scrollY > 500) {
          mobileStickyBar.classList.remove('translate-y-full');
        } else {
          mobileStickyBar.classList.add('translate-y-full');
        }
      };
      window.addEventListener('scroll', handleMobileScroll, { passive: true });
      handleMobileScroll();
    }

    // --- Enquiry Forms ---
    document.querySelectorAll('.hero-enquiry-form').forEach((form) => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const f = e.target as HTMLFormElement;
        const msg = f.querySelector('.enquiry-msg') as HTMLElement;
        const btn = f.querySelector('button[type="submit"]') as HTMLButtonElement;
        const origText = btn.textContent;
        btn.textContent = 'Sending...';
        btn.disabled = true;

        try {
          const formData = new FormData(f);
          const res = await fetch('/api/enquiry', { method: 'POST', body: formData });
          if (res.ok) {
            msg.textContent = 'Thank you! We will be in touch shortly.';
            msg.classList.remove('hidden', 'text-red-600');
            msg.classList.add('text-green-600');
            f.reset();
          } else {
            // Pull the error reason from JSON body (preferred) or text body
            let reason = `HTTP ${res.status}`;
            try {
              const j = await res.clone().json();
              if (j?.error) reason = j.error;
            } catch {
              try { const t = (await res.text()).trim(); if (t) reason = t; } catch { /* */ }
            }
            throw new Error(reason);
          }
        } catch (err) {
          const detail = err instanceof Error ? err.message : 'Please try again.';
          msg.textContent = `Sorry — ${detail}`;
          msg.classList.remove('hidden', 'text-green-600');
          msg.classList.add('text-red-600');
        } finally {
          btn.textContent = origText;
          btn.disabled = false;
        }
      });
    });
  });
</script>
