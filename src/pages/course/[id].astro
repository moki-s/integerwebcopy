---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Testimonials from '../../components/Testimonials.astro';
import CTA from '../../components/CTA.astro';
import SectionDivider from '../../components/SectionDivider.astro';
import { siteConfig } from '../../data/site-config';
import { COURSES, categoryToSlug, type Course } from '../../data/courses';

export function getStaticPaths() {
  return Object.values(COURSES).map((course) => ({
    params: { id: course.id },
    props: { course },
  }));
}

const { course } = Astro.props as { course: Course };
const categorySlug = categoryToSlug[course.category] || 'accounting';
const savings = course.oldPrice - course.price;

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Courses', href: '/courses' },
  { label: course.category, href: `/courses/${categorySlug}` },
  { label: course.title, href: `/course/${course.id}` },
];

const defaultFaqs = [
  { question: 'Do I need prior qualifications to enrol?', answer: course.entryRequirements || 'Most of our courses have no specific entry requirements. Some advanced qualifications (Level 3+) may recommend prior knowledge or a lower-level qualification in the same subject. Contact our team if you are unsure about eligibility.' },
  { question: 'How much time do I need per week?', answer: 'We recommend around 10-15 hours per week for most courses. However, since our courses are fully online and self-paced, you can study at a schedule that fits around your work and personal commitments.' },
  { question: 'Is the qualification recognised by employers?', answer: 'Yes. All our courses lead to nationally recognised, Ofqual-regulated qualifications. They are accepted by employers, professional bodies, and further education providers across the UK.' },
  { question: 'What support is available during my studies?', answer: 'Every learner receives dedicated 1-to-1 tutor support throughout their course. You can contact your assigned tutor via email or phone during business hours. We also provide comprehensive study materials and resources.' },
  { question: 'How is the course assessed?', answer: course.assessmentType || 'Assessment is conducted online through a combination of multiple-choice exams and coursework assignments. You can take exams from home at a time that suits you, with full support from your tutor.' },
];
const faqs = course.faqs || defaultFaqs;

// Related courses from same category
const relatedCourses = Object.values(COURSES)
  .filter((c) => c.category === course.category && c.id !== course.id)
  .slice(0, 3);

// Category-based career & salary data
const careerData: Record<string, { avgSalary: string; roles: { title: string; salary: string }[] }> = {
  'Accounting': {
    avgSalary: '£35,000+',
    roles: [
      { title: 'Accounts Assistant', salary: '£22k - £26k' },
      { title: 'Bookkeeper', salary: '£24k - £30k' },
      { title: 'Finance Officer', salary: '£28k - £35k' },
      { title: 'Management Accountant', salary: '£35k - £50k' },
    ],
  },
  'Health & Social Care': {
    avgSalary: '£28,000+',
    roles: [
      { title: 'Care Worker', salary: '£20k - £24k' },
      { title: 'Senior Care Assistant', salary: '£23k - £28k' },
      { title: 'Care Home Manager', salary: '£28k - £40k' },
      { title: 'Social Worker', salary: '£30k - £42k' },
    ],
  },
  'Business & Management': {
    avgSalary: '£32,000+',
    roles: [
      { title: 'Team Leader', salary: '£24k - £30k' },
      { title: 'Office Manager', salary: '£26k - £34k' },
      { title: 'Operations Manager', salary: '£32k - £45k' },
      { title: 'Business Manager', salary: '£35k - £50k' },
    ],
  },
  'Functional Skills': {
    avgSalary: '£25,000+',
    roles: [
      { title: 'Administrative Assistant', salary: '£20k - £24k' },
      { title: 'Customer Service Advisor', salary: '£21k - £26k' },
      { title: 'Data Entry Clerk', salary: '£20k - £25k' },
      { title: 'Teaching Assistant', salary: '£22k - £27k' },
    ],
  },
  'Security & Stewarding': {
    avgSalary: '£27,000+',
    roles: [
      { title: 'Door Supervisor', salary: '£22k - £28k' },
      { title: 'Security Officer', salary: '£22k - £30k' },
      { title: 'Event Steward', salary: '£20k - £26k' },
      { title: 'Security Manager', salary: '£30k - £42k' },
    ],
  },
  'Occupational Studies': {
    avgSalary: '£24,000+',
    roles: [
      { title: 'Administrative Assistant', salary: '£20k - £24k' },
      { title: 'Customer Service Advisor', salary: '£21k - £26k' },
      { title: 'Office Coordinator', salary: '£22k - £28k' },
      { title: 'Operations Assistant', salary: '£22k - £27k' },
    ],
  },
};

// Use per-course career data if available, otherwise fall back to category defaults
const career = {
  avgSalary: course.avgSalary || (careerData[course.category] || careerData['Occupational Studies']).avgSalary,
  roles: course.careerRoles || (careerData[course.category] || careerData['Occupational Studies']).roles,
};

// Course schema JSON-LD
const courseSchema = {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": course.title,
  "description": course.overview,
  "provider": {
    "@type": "Organization",
    "name": "Integer Training",
    "url": "https://www.integertraining.com",
    "sameAs": "https://www.integertraining.com"
  },
  "offers": {
    "@type": "Offer",
    "price": course.price,
    "priceCurrency": "GBP",
    "availability": "https://schema.org/InStock",
    "url": `https://www.integertraining.com/course/${course.id}`
  },
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "online",
    "courseSchedule": {
      "@type": "Schedule",
      "repeatFrequency": "P1D"
    }
  }
};
---

<BaseLayout
  title={course.metaTitle || `${course.title} | Online Course | Integer Training`}
  description={course.metaDescription || `${course.overview} Enrol today from just £${course.price}. Accredited, fully online with tutor support. 0% finance available.`}
>
  <!-- Course Schema Markup -->
  <script type="application/ld+json" set:html={JSON.stringify(courseSchema)} />

  <Breadcrumb items={breadcrumbs} />

  <!-- Top Promo Banner (LearnDirect-style) -->
  <div class="bg-gradient-to-r from-primary-600 to-primary-700 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-2.5 flex items-center justify-center gap-3 text-sm">
      <svg class="w-5 h-5 text-accent-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
      <span><strong>Flexible Payment Options</strong> &mdash; Enrol today from just &pound;{course.monthlyPrice}/month interest-free</span>
      <a href="#sidebar-pricing" class="hidden sm:inline-flex items-center bg-accent-500 text-neutral-900 font-bold px-3 py-1 rounded-lg text-xs hover:bg-accent-400 transition-colors">
        ENROL NOW
      </a>
    </div>
  </div>

  <!-- Hero Section with salary hook -->
  <section class="bg-gradient-to-br from-neutral-900 via-neutral-800 to-neutral-900 text-white py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center gap-3 mb-4">
        <span
          class="text-xs font-bold px-3 py-1 rounded-full text-white"
          style={`background-color: ${course.badgeColor};`}
        >
          {course.badge}
        </span>
        <span class="text-xs text-neutral-400 uppercase tracking-wider">{course.category}</span>
        {savings > 0 && (
          <span class="text-xs font-bold px-3 py-1 rounded-full bg-red-500 text-white">
            SAVE &pound;{savings}
          </span>
        )}
      </div>
      <h1 class="font-display font-bold text-3xl md:text-4xl lg:text-5xl mb-4 leading-tight">
        {course.title}
      </h1>
      <!-- Salary hook - like competitor's "average salary of £40,000+" -->
      <div class="bg-white/10 backdrop-blur-sm rounded-xl px-5 py-3 mb-6 inline-block">
        <p class="text-sm text-neutral-200">
          Work towards a career in {course.category.toLowerCase()}, with an average salary of
          <span class="text-accent-400 font-bold text-base">{career.avgSalary} per annum</span>
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-6 text-sm text-neutral-200">
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          {course.students.toLocaleString()}+ students enrolled
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
          100% Online Course
        </span>
        <span class="flex items-center gap-2">
          <svg class="w-5 h-5 text-accent-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg>
          Start Immediately
        </span>
      </div>
    </div>
  </section>

  <!-- Above-the-fold Enquiry Form (Google Ads optimised - captures high-intent traffic immediately) -->
  <section class="bg-neutral-50 border-b border-neutral-200" id="enquiry-section">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="lg:grid lg:grid-cols-2 lg:gap-10 items-start">
        <!-- Left: Value proposition + trust signals -->
        <div class="mb-6 lg:mb-0">
          <h2 class="font-display font-bold text-xl lg:text-2xl text-neutral-900 mb-3">Get Expert Course Advice</h2>
          <p class="text-neutral-600 text-sm mb-5">Speak with a dedicated course advisor about funding options, start dates, and how this qualification can advance your career.</p>
          <div class="grid grid-cols-2 gap-3 mb-5">
            <div class="flex items-center gap-2 text-sm text-neutral-700">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span>Free, no-obligation advice</span>
            </div>
            <div class="flex items-center gap-2 text-sm text-neutral-700">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span>Response within 24 hours</span>
            </div>
            <div class="flex items-center gap-2 text-sm text-neutral-700">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span>0% finance guidance</span>
            </div>
            <div class="flex items-center gap-2 text-sm text-neutral-700">
              <svg class="w-5 h-5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
              <span>Career pathway support</span>
            </div>
          </div>
          <!-- Trustpilot-style social proof directly below (competitor pattern) -->
          <div class="flex items-center gap-3 bg-white rounded-xl px-4 py-3 border border-neutral-100">
            <div class="flex items-center gap-0.5">
              {[1,2,3,4,5].map(() => (
                <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            <div>
              <span class="text-sm font-bold text-neutral-900">{siteConfig.stats.trustpilotRating}/5</span>
              <span class="text-xs text-neutral-500 ml-1">from {siteConfig.stats.trustpilotReviews}+ reviews on Trustpilot</span>
            </div>
          </div>
        </div>

        <!-- Right: Compact enquiry form -->
        <div class="bg-white rounded-2xl border border-neutral-200 shadow-brand-sm overflow-hidden">
          <div class="bg-neutral-900 text-white px-5 py-3">
            <h3 class="font-display font-bold text-base">Enquire About This Course</h3>
            <p class="text-neutral-400 text-xs mt-0.5">Or call us free: <a href="tel:01216909563" class="text-accent-400 font-semibold hover:underline">0121 690 9563</a></p>
          </div>
          <form class="hero-enquiry-form p-5 space-y-3" data-course-name={course.title}>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
              <input type="text" name="name" placeholder="Full Name *" required class="w-full px-4 py-2.5 rounded-xl border border-neutral-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
              <input type="tel" name="phone" placeholder="Phone Number *" required class="w-full px-4 py-2.5 rounded-xl border border-neutral-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
            </div>
            <input type="email" name="email" placeholder="Email Address *" required class="w-full px-4 py-2.5 rounded-xl border border-neutral-200 text-sm focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
            <input type="hidden" name="course_interest" value={course.title} />
            <input type="hidden" name="page" value={`/course/${course.id}`} />
            <input type="hidden" name="utm_source" class="utm-source" value="" />
            <input type="hidden" name="utm_campaign" class="utm-campaign" value="" />
            <div class="hidden"><input type="text" name="website" /></div>
            <button type="submit" class="w-full bg-gradient-to-r from-accent-500 to-accent-600 text-neutral-900 font-bold py-3 rounded-xl shadow-brand hover:shadow-brand-lg transition-all duration-300 text-sm">
              Get Free Course Advice
            </button>
            <p class="enquiry-msg text-sm text-center hidden"></p>
            <p class="text-[11px] text-neutral-400 text-center leading-tight">By submitting, you agree to our <a href="/privacy-policy" class="underline">Privacy Policy</a>. We'll never share your details.</p>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- Pass Rate + Course Stats (LearnDirect-inspired) -->
  <section class="bg-neutral-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-0">
      <div class="grid grid-cols-2 lg:grid-cols-4 divide-x divide-white/10">
        <div class="py-5 px-4 text-center">
          <div class="text-3xl lg:text-4xl font-bold text-accent-400">{course.passRate || 93}%</div>
          <div class="text-xs text-neutral-300 mt-1 font-medium">Pass Rate</div>
        </div>
        <div class="py-5 px-4 text-center">
          <div class="text-3xl lg:text-4xl font-bold text-white">100%</div>
          <div class="text-xs text-neutral-300 mt-1 font-medium">Online Learning</div>
        </div>
        <div class="py-5 px-4 text-center">
          <div class="text-3xl lg:text-4xl font-bold text-white">{course.units || course.curriculum.length}</div>
          <div class="text-xs text-neutral-300 mt-1 font-medium">Course Units</div>
        </div>
        <div class="py-5 px-4 text-center">
          <div class="text-3xl lg:text-4xl font-bold text-white">{course.duration || '6-12'}<span class="text-lg font-normal"> mo</span></div>
          <div class="text-xs text-neutral-300 mt-1 font-medium">Avg. Completion</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Main Content + Sidebar -->
  <section class="py-12 lg:py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="lg:grid lg:grid-cols-3 lg:gap-12">
        <!-- Main Content (2 cols) -->
        <div class="lg:col-span-2">
          <!-- Tabs -->
          <div class="border-b border-neutral-200 mb-8">
            <div class="flex gap-0" role="tablist">
              <button
                class="tab-btn px-6 py-3 font-semibold text-sm border-b-2 border-primary-500 text-primary-600 transition-all duration-200"
                role="tab"
                aria-selected="true"
                data-tab="overview"
              >
                Overview
              </button>
              <button
                class="tab-btn px-6 py-3 font-semibold text-sm border-b-2 border-transparent text-neutral-500 hover:text-neutral-700 transition-all duration-200"
                role="tab"
                aria-selected="false"
                data-tab="curriculum"
              >
                Curriculum
              </button>
            </div>
          </div>

          <!-- Overview Tab -->
          <div id="tab-overview" class="tab-panel">
            <!-- Course at a Glance (LearnDirect-inspired) -->
            <div class="mb-10 bg-white rounded-2xl border-2 border-primary-200 p-6">
              <h2 class="font-display font-bold text-lg text-primary-700 mb-4 flex items-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                This Course at a Glance
              </h2>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-2.5">
                {(course.glancePoints || [
                  `${course.curriculum.length} comprehensive units of study`,
                  '100% online - study from anywhere',
                  'Self-paced: fit learning around your life',
                  'Dedicated 1-to-1 tutor support',
                  `From just £${course.monthlyPrice}/month interest-free`,
                  'Nationally recognised qualification',
                ]).map((point) => (
                  <li class="flex items-start gap-2 text-sm text-neutral-800">
                    <svg class="w-4 h-4 text-primary-500 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                    {point}
                  </li>
                ))}
              </ul>
            </div>

            <div class="prose prose-neutral max-w-none mb-12">
              <h2 class="font-display font-bold text-2xl text-neutral-900 mb-4">About This Course</h2>
              <p class="text-base text-neutral-800 leading-relaxed">{course.overview}</p>
              {course.description && <div class="mt-4 text-neutral-700 leading-relaxed" set:html={course.description} />}
            </div>

            <!-- What's Included (competitor-inspired) -->
            <div class="mb-12 bg-primary-50 rounded-2xl p-6 border border-primary-100">
              <h2 class="font-display font-bold text-xl text-primary-700 mb-4">Your course includes:</h2>
              <ul class="space-y-3">
                {(course.whatsIncluded || [
                  'Industry-leading eLearning platform with 24/7 access',
                  'Dedicated 1-to-1 tutor support via email and phone',
                  'Comprehensive study materials and practice assessments',
                  'Official courseware, revision guides, and question banks',
                  'Online exam booking and assessment support',
                  'Certificate upon successful completion',
                  'Lifetime access to course materials',
                ]).map((item) => (
                  <li class="flex items-start gap-3">
                    <svg class="w-5 h-5 text-green-600 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>
                    <span class="text-sm font-medium text-neutral-800">{item}</span>
                  </li>
                ))}
              </ul>
            </div>

            <!-- Why Study This Course -->
            <div class="mb-12">
              <h2 class="font-display font-bold text-2xl text-neutral-900 mb-6">Why study this course?</h2>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div class="flex items-center gap-3 p-4 bg-primary-50 rounded-xl">
                  <div class="w-8 h-8 rounded-lg bg-primary-500 text-white flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>
                  </div>
                  <span class="font-semibold text-neutral-900">Accredited qualification</span>
                </div>
                <div class="flex items-center gap-3 p-4 bg-primary-50 rounded-xl">
                  <div class="w-8 h-8 rounded-lg bg-primary-500 text-white flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                  </div>
                  <span class="font-semibold text-neutral-900">100% Online learning</span>
                </div>
                <div class="flex items-center gap-3 p-4 bg-primary-50 rounded-xl">
                  <div class="w-8 h-8 rounded-lg bg-primary-500 text-white flex items-center justify-center flex-shrink-0">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                  </div>
                  <span class="font-semibold text-neutral-900">Tutor support included</span>
                </div>
                <div class="flex items-center gap-3 p-4 bg-primary-50 rounded-xl">
                  <div class="w-8 h-8 rounded-lg bg-primary-500 text-white flex items-center justify-center flex-shrink-0">
