---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | Integer Training" description="The page you're looking for doesn't exist.">
  <section class="py-32 lg:py-48">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-8xl font-display font-bold text-primary-200 mb-4">404</p>
      <h1 class="font-display font-bold text-3xl md:text-4xl text-neutral-900 mb-4">Page Not Found</h1>
      <p class="text-neutral-600 text-lg mb-8">Sorry, we couldn't find the page you're looking for. It may have been moved or no longer exists.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a href="/" class="bg-gradient-to-r from-primary-500 to-primary-600 text-white px-6 py-3 rounded-xl font-semibold shadow-brand hover:shadow-brand-lg transition-all duration-300">
          Go to Homepage
        </a>
        <a href="/courses" class="border border-neutral-200 text-neutral-700 px-6 py-3 rounded-xl font-semibold hover:border-primary-200 hover:text-primary-600 transition-all duration-300">
          Browse Courses
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
