---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import SectionDivider from '../components/SectionDivider.astro';
import { siteConfig } from '../data/site-config';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Student Login', href: '/login' },
];
---

<BaseLayout
  title="Student Login | Integer Training"
  description="Log in to access your Integer Training course materials, track progress, and download certificates."
>
  <Breadcrumb items={breadcrumbs} />

  <section class="py-24 lg:py-32">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16">
        <!-- Left: Login -->
        <div>
          <h1 class="font-display font-bold text-3xl md:text-4xl text-neutral-900 mb-4">Student Login</h1>
          <p class="text-neutral-600 mb-8">Welcome back! Please access your course material below.</p>

          <div class="bg-neutral-50 border border-neutral-200 rounded-2xl p-8">
            <div class="flex items-center gap-3 mb-4">
              <svg class="w-6 h-6 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
              <span class="font-semibold text-neutral-900">Coming Soon</span>
            </div>
            <p class="text-neutral-600 text-sm leading-relaxed">
              Student login is coming soon. Please contact us at
              <a href={`mailto:${siteConfig.email}`} class="text-primary-500 hover:text-primary-600 font-medium underline">{siteConfig.email}</a>
              for course access.
            </p>
          </div>
        </div>

        <!-- Right: New Student -->
        <div class="md:border-l md:border-neutral-200 md:pl-16">
          <h2 class="font-display font-bold text-2xl text-neutral-900 mb-4">New to Integer?</h2>
          <p class="text-neutral-600 mb-8">Create an account to track your orders and access your courses.</p>

          <ul class="space-y-4 mb-8">
            {[
              { icon: 'M13 10V3L4 14h7v7l9-11h-7z', text: 'Instant access to course materials' },
              { icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', text: 'Track your progress' },
              { icon: 'M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z', text: 'Download certificates' },
            ].map((item) => (
              <li class="flex items-center gap-3 text-neutral-700">
                <div class="w-8 h-8 rounded-lg bg-primary-50 text-primary-500 flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} /></svg>
                </div>
                {item.text}
              </li>
            ))}
          </ul>

          <a
            href="/courses"
            class="inline-flex items-center gap-2 bg-gradient-to-r from-primary-500 to-primary-600 text-white px-6 py-3 rounded-xl font-semibold shadow-brand hover:shadow-brand-lg hover:-translate-y-0.5 transition-all duration-300"
          >
            Browse Courses
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <SectionDivider fillColor="#0f172a" variant="curve" />
</BaseLayout>
