# Stripe
STRIPE_SECRET_KEY=sk_live_xxx
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
# Required for /api/stripe-webhook signature verification.
# Obtain from Stripe dashboard → Developers → Webhooks → endpoint signing secret.
# For local dev use the value printed by `stripe listen`.
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=xxx
SUPABASE_SERVICE_ROLE_KEY=xxx

# Resend (email)
RESEND_API_KEY=re_xxx
